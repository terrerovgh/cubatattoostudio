---
---

<section id="artists" class="min-h-screen py-20 px-8 relative z-20">
  <div class="max-w-7xl mx-auto">
    <div class="text-center mb-16 scroll-animate" data-animation="fadeIn">
      <h2 class="text-5xl md:text-7xl font-bold text-white mb-6 tracking-wider">
        NUESTROS ARTISTAS
      </h2>
      <p class="text-xl text-gray-300 max-w-3xl mx-auto leading-relaxed">
        Conoce a los talentosos artistas que dan vida a tus ideas. Cada uno con su estilo único y años de experiencia.
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-12">
      <!-- Artista 1 -->
      <div class="group text-center scroll-animate" data-animation="fadeIn" data-delay="0.2">
        <div class="relative mb-6 overflow-hidden rounded-2xl">
          <img 
            src="/artists/david/artist-david.jpg" 
            alt="David - Especialista en Realismo"
            class="w-full h-80 object-cover group-hover:scale-110 transition-transform duration-500"
          />
          <div class="absolute inset-0 bg-black bg-opacity-0 group-hover:bg-opacity-20 transition-all duration-500"></div>
        </div>
        <h3 class="text-2xl font-bold text-white mb-2">David</h3>
        <p class="text-amber-400 font-semibold mb-4">Especialista en Realismo</p>
        <p class="text-gray-300 leading-relaxed mb-6">
          Con más de 10 años de experiencia, David se especializa en retratos hiperrealistas y tatuajes en blanco y negro que capturan cada detalle con precisión fotográfica.
        </p>
        <div class="flex justify-center space-x-4">
          <button class="w-10 h-10 bg-amber-400 rounded-full flex items-center justify-center hover:bg-amber-300 transition-colors duration-300">
            <svg class="w-5 h-5 text-black" fill="currentColor" viewBox="0 0 24 24">
              <path d="M24 4.557c-.883.392-1.832.656-2.828.775 1.017-.609 1.798-1.574 2.165-2.724-.951.564-2.005.974-3.127 1.195-.897-.957-2.178-1.555-3.594-1.555-3.179 0-5.515 2.966-4.797 6.045-4.091-.205-7.719-2.165-10.148-5.144-1.29 2.213-.669 5.108 1.523 6.574-.806-.026-1.566-.247-2.229-.616-.054 2.281 1.581 4.415 3.949 4.89-.693.188-1.452.232-2.224.084.626 1.956 2.444 3.379 4.6 3.419-2.07 1.623-4.678 2.348-7.29 2.04 2.179 1.397 4.768 2.212 7.548 2.212 9.142 0 14.307-7.721 13.995-14.646.962-.695 1.797-1.562 2.457-2.549z"/>
            </svg>
          </button>
          <button class="w-10 h-10 bg-amber-400 rounded-full flex items-center justify-center hover:bg-amber-300 transition-colors duration-300">
            <svg class="w-5 h-5 text-black" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12.017 0C5.396 0 .029 5.367.029 11.987c0 5.079 3.158 9.417 7.618 11.174-.105-.949-.199-2.405.042-3.441.219-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738.098.119.112.224.083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.357-.631-2.746-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24.009 12.017 24.009c6.624 0 11.99-5.367 11.99-11.988C24.007 5.367 18.641.001.012.001z"/>
            </svg>
          </button>
        </div>
      </div>

      <!-- Artista 2 -->
      <div class="group text-center scroll-animate" data-animation="fadeIn" data-delay="0.4">
        <div class="relative mb-6 overflow-hidden rounded-2xl">
          <img 
            src="/artists/karli/artist-karli.jpg" 
            alt="Karli - Maestra del Color"
            class="w-full h-80 object-cover group-hover:scale-110 transition-transform duration-500"
          />
          <div class="absolute inset-0 bg-black bg-opacity-0 group-hover:bg-opacity-20 transition-all duration-500"></div>
        </div>
        <h3 class="text-2xl font-bold text-white mb-2">Karli</h3>
        <p class="text-amber-400 font-semibold mb-4">Maestra del Color</p>
        <p class="text-gray-300 leading-relaxed mb-6">
          Karli es una experta en tatuajes a color vibrantes y diseños florales. Su técnica de sombreado y mezcla de colores es reconocida internacionalmente.
        </p>
        <div class="flex justify-center space-x-4">
          <button class="w-10 h-10 bg-amber-400 rounded-full flex items-center justify-center hover:bg-amber-300 transition-colors duration-300">
            <svg class="w-5 h-5 text-black" fill="currentColor" viewBox="0 0 24 24">
              <path d="M24 4.557c-.883.392-1.832.656-2.828.775 1.017-.609 1.798-1.574 2.165-2.724-.951.564-2.005.974-3.127 1.195-.897-.957-2.178-1.555-3.594-1.555-3.179 0-5.515 2.966-4.797 6.045-4.091-.205-7.719-2.165-10.148-5.144-1.29 2.213-.669 5.108 1.523 6.574-.806-.026-1.566-.247-2.229-.616-.054 2.281 1.581 4.415 3.949 4.89-.693.188-1.452.232-2.224.084.626 1.956 2.444 3.379 4.6 3.419-2.07 1.623-4.678 2.348-7.29 2.04 2.179 1.397 4.768 2.212 7.548 2.212 9.142 0 14.307-7.721 13.995-14.646.962-.695 1.797-1.562 2.457-2.549z"/>
            </svg>
          </button>
          <button class="w-10 h-10 bg-amber-400 rounded-full flex items-center justify-center hover:bg-amber-300 transition-colors duration-300">
            <svg class="w-5 h-5 text-black" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12.017 0C5.396 0 .029 5.367.029 11.987c0 5.079 3.158 9.417 7.618 11.174-.105-.949-.199-2.405.042-3.441.219-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738.098.119.112.224.083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.357-.631-2.746-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24.009 12.017 24.009c6.624 0 11.99-5.367 11.99-11.988C24.007 5.367 18.641.001.012.001z"/>
            </svg>
          </button>
        </div>
      </div>

      <!-- Artista 3 -->
      <div class="group text-center scroll-animate" data-animation="fadeIn" data-delay="0.6">
        <div class="relative mb-6 overflow-hidden rounded-2xl">
          <img 
            src="/artists/nina/artist-nina.jpg" 
            alt="Nina - Especialista en Geometría"
            class="w-full h-80 object-cover group-hover:scale-110 transition-transform duration-500"
          />
          <div class="absolute inset-0 bg-black bg-opacity-0 group-hover:bg-opacity-20 transition-all duration-500"></div>
        </div>
        <h3 class="text-2xl font-bold text-white mb-2">Nina</h3>
        <p class="text-amber-400 font-semibold mb-4">Especialista en Geometría</p>
        <p class="text-gray-300 leading-relaxed mb-6">
          Nina crea diseños geométricos perfectos y mandalas intrincados. Su precisión en líneas y patrones es extraordinaria, combinando arte moderno con simbolismo ancestral.
        </p>
        <div class="flex justify-center space-x-4">
          <button class="w-10 h-10 bg-amber-400 rounded-full flex items-center justify-center hover:bg-amber-300 transition-colors duration-300">
            <svg class="w-5 h-5 text-black" fill="currentColor" viewBox="0 0 24 24">
              <path d="M24 4.557c-.883.392-1.832.656-2.828.775 1.017-.609 1.798-1.574 2.165-2.724-.951.564-2.005.974-3.127 1.195-.897-.957-2.178-1.555-3.594-1.555-3.179 0-5.515 2.966-4.797 6.045-4.091-.205-7.719-2.165-10.148-5.144-1.29 2.213-.669 5.108 1.523 6.574-.806-.026-1.566-.247-2.229-.616-.054 2.281 1.581 4.415 3.949 4.89-.693.188-1.452.232-2.224.084.626 1.956 2.444 3.379 4.6 3.419-2.07 1.623-4.678 2.348-7.29 2.04 2.179 1.397 4.768 2.212 7.548 2.212 9.142 0 14.307-7.721 13.995-14.646.962-.695 1.797-1.562 2.457-2.549z"/>
            </svg>
          </button>
          <button class="w-10 h-10 bg-amber-400 rounded-full flex items-center justify-center hover:bg-amber-300 transition-colors duration-300">
            <svg class="w-5 h-5 text-black" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12.017 0C5.396 0 .029 5.367.029 11.987c0 5.079 3.158 9.417 7.618 11.174-.105-.949-.199-2.405.042-3.441.219-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738.098.119.112.224.083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.357-.631-2.746-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24.009 12.017 24.009c6.624 0 11.99-5.367 11.99-11.988C24.007 5.367 18.641.001.012.001z"/>
            </svg>
          </button>
        </div>
      </div>
    </div>

    <div class="text-center mt-16 scroll-animate" data-animation="fadeIn" data-delay="0.8">
      <h3 class="text-3xl font-bold text-white mb-6">¿Listo para trabajar con nosotros?</h3>
      <p class="text-xl text-gray-300 mb-8 max-w-2xl mx-auto">
        Nuestros artistas están listos para convertir tu visión en realidad. Agenda una consulta y descubre cuál es el artista perfecto para tu próximo tatuaje.
      </p>
      <button class="bg-amber-400 text-black px-8 py-4 rounded-full font-bold text-lg hover:bg-amber-300 transition-colors duration-300 hover:scale-105 transform">
        Conoce a Nuestro Equipo
      </button>
    </div>
  </div>
</section>


