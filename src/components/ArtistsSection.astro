---
import ArtistDavid from './ArtistDavid.astro';
import ArtistNina from './ArtistNina.astro';
import ArtistKarli from './ArtistKarli.astro';
import Heading from './Heading.astro';
import Button from './Button.astro';
---

<section id="artists" class="min-h-screen py-20 px-8 relative z-20">
  <div class="max-w-7xl mx-auto">
    <div class="text-center mb-16 scroll-animate" data-animation="fadeIn">
      <Heading level={2} size="4xl" variant="primary" class="mb-6 tracking-wider">
        NUESTROS ARTISTAS
      </Heading>
      <p class="text-xl text-gray-300 max-w-3xl mx-auto leading-relaxed">
        Conoce a los talentosos artistas que dan vida a tus ideas. Cada uno con su estilo único y años de experiencia.
      </p>
    </div>

    <!-- Grid de artistas individuales -->
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 mb-16">
      <div class="scroll-animate" data-animation="fadeIn" data-delay="0.2">
        <ArtistDavid />
      </div>
      
      <div class="scroll-animate" data-animation="fadeIn" data-delay="0.4">
        <ArtistNina />
      </div>
      
      <div class="scroll-animate" data-animation="fadeIn" data-delay="0.6">
        <ArtistKarli />
      </div>
    </div>

    <!-- Call to Action -->
    <div class="text-center scroll-animate" data-animation="fadeIn" data-delay="0.8">
      <Heading level={3} size="2xl" variant="primary" class="mb-6">
        ¿Listo para trabajar con nosotros?
      </Heading>
      <p class="text-xl text-gray-300 mb-8 max-w-2xl mx-auto">
        Nuestros artistas están listos para convertir tu visión en realidad. Agenda una consulta y descubre cuál es el artista perfecto para tu próximo tatuaje.
      </p>
      <Button variant="primary" size="lg" class="hover:scale-105 transform">
        Conoce a Nuestro Equipo
      </Button>
    </div>
  </div>
</section>


