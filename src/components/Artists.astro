---
import { ArrowRight } from "lucide-react";
import { supabase } from "../lib/supabase";
import { getCollection } from "astro:content";

let artists: any[] | null = null
const { data, error } = await supabase
  .from('artists')
  .select('*')
  .eq('is_active', true)
  .order('display_order')
if (error) {
  console.error('Error fetching artists:', error)
}
artists = data || null
if (!artists || artists.length === 0) {
  const contentArtists = await getCollection("artists")
  artists = contentArtists.map((entry) => ({
    slug: entry.slug,
    name: entry.data.name,
    specialty: (entry.data.specialties || []).join(' & '),
    bio: entry.data.bio,
    avatar_url: entry.data.profileImage,
  }))
}
---

<section id="artists" class="py-20 md:py-32 bg-neutral-950 overflow-hidden">
    <div class="max-w-7xl mx-auto px-6">
        <div class="mb-32 text-center reveal-hidden">
            <span
                class="text-xs font-medium tracking-widest uppercase text-neutral-500 mb-4 block"
                >The Talent</span
            >
            <h3
                class="text-4xl md:text-6xl font-medium tracking-tighter text-white"
            >
                The Artists.
            </h3>
        </div>

        {
            (artists || []).map((artist, index) => (
                <div
                    class={`flex flex-col ${index % 2 === 1 ? "md:flex-row-reverse" : "md:flex-row"} items-center gap-12 mb-32 reveal-hidden group`}
                >
                    <div class="w-full md:w-1/2 relative aspect-[4/5] md:aspect-square overflow-hidden rounded-2xl">
                        <img
                            src={artist.avatar_url}
                            alt={`${artist.name} Portfolio`}
                            class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105 filter grayscale group-hover:grayscale-0"
                        />
                    </div>
                    <div
                        class={`w-full md:w-1/2 ${index % 2 === 1 ? "md:pr-12 text-right md:text-left" : "md:pl-12"}`}
                    >
                        <div
                            class={`flex items-center ${index % 2 === 1 ? "justify-end md:justify-start" : ""} gap-4 mb-2`}
                        >
                            <span
                                class={`h-px w-8 bg-neutral-700 ${index % 2 === 1 ? "order-last md:order-first" : ""}`}
                            />
                            <span class="text-xs font-medium tracking-widest uppercase text-neutral-500">
                                {artist.specialty}
                            </span>
                        </div>
                        <h4 class="text-5xl md:text-7xl font-medium tracking-tighter text-white mb-6">
                            {artist.name}.
                        </h4>
                        <p
                            class={`text-neutral-400 text-lg font-light leading-relaxed mb-8 max-w-md ${index % 2 === 1 ? "ml-auto md:ml-0" : ""}`}
                        >
                            {artist.bio}
                        </p>
                        <div
                            class={`flex ${index % 2 === 1 ? "justify-end md:justify-start" : ""}`}
                        >
                            <a
                                href={`/artists/${artist.slug}`}
                                class="inline-flex items-center text-sm font-medium hover:text-neutral-300 transition-colors border-b border-neutral-700 pb-1"
                            >
                                View {artist.name}'s Portfolio{" "}
                                <ArrowRight className="ml-2 w-4 h-4" />
                            </a>
                        </div>
                    </div>
                </div>
            ))
        }
    </div>
</section>
