---
import { ArrowRight } from "lucide-react";
---

<section id="artists" class="py-20 md:py-32 bg-neutral-950 overflow-hidden">
    <div class="max-w-7xl mx-auto px-6">
        <div class="mb-32 text-center reveal-hidden">
            <span
                class="text-xs font-medium tracking-widest uppercase text-neutral-500 mb-4 block"
                >The Talent</span
            >
            <h3
                class="text-4xl md:text-6xl font-medium tracking-tighter text-white"
            >
                The Artists.
            </h3>
        </div>

        <!-- Artist: David -->
        <div
            class="flex flex-col md:flex-row items-center gap-12 mb-32 reveal-hidden group"
        >
            <div
                class="w-full md:w-1/2 relative aspect-[4/5] md:aspect-square overflow-hidden rounded-2xl"
            >
                <img
                    src="/artists/david.png"
                    alt="David Portfolio"
                    class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105 filter grayscale group-hover:grayscale-0"
                />
            </div>
            <div class="w-full md:w-1/2 md:pl-12">
                <div class="flex items-center gap-4 mb-2">
                    <span class="h-px w-8 bg-neutral-700"></span>
                    <span
                        class="text-xs font-medium tracking-widest uppercase text-neutral-500"
                        >Blackwork & Realism</span
                    >
                </div>
                <h4
                    class="text-5xl md:text-7xl font-medium tracking-tighter text-white mb-6"
                >
                    David.
                </h4>
                <p
                    class="text-neutral-400 text-lg font-light leading-relaxed mb-8 max-w-md"
                >
                    Mastering shadow and light, David specializes in
                    high-contrast photorealism and large-scale blackwork
                    projects. His work transforms skin into a monochrome canvas
                    of depth.
                </p>
                <a
                    href="/artists/david"
                    class="inline-flex items-center text-sm font-medium hover:text-neutral-300 transition-colors border-b border-neutral-700 pb-1"
                >
                    View David's Portfolio <ArrowRight
                        className="ml-2 w-4 h-4"
                    />
                </a>
            </div>
        </div>

        <!-- Artist: Nina -->
        <div
            class="flex flex-col md:flex-row-reverse items-center gap-12 mb-32 reveal-hidden group"
        >
            <div
                class="w-full md:w-1/2 relative aspect-[4/5] md:aspect-square overflow-hidden rounded-2xl"
            >
                <img
                    src="/artists/nina.png"
                    alt="Nina Portfolio"
                    class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105 filter grayscale group-hover:grayscale-0"
                />
            </div>
            <div class="w-full md:w-1/2 md:pr-12 text-right md:text-left">
                <div
                    class="flex items-center justify-end md:justify-start gap-4 mb-2"
                >
                    <span
                        class="h-px w-8 bg-neutral-700 order-last md:order-first"
                    ></span>
                    <span
                        class="text-xs font-medium tracking-widest uppercase text-neutral-500"
                        >Fine Line & Floral</span
                    >
                </div>
                <h4
                    class="text-5xl md:text-7xl font-medium tracking-tighter text-white mb-6"
                >
                    Nina.
                </h4>
                <p
                    class="text-neutral-400 text-lg font-light leading-relaxed mb-8 max-w-md ml-auto md:ml-0"
                >
                    Delicacy is strength. Nina brings botanical illustrations
                    and single-needle geometry to life. Her touch is light, her
                    lines are impeccable, and her art flows with the body's
                    natural curves.
                </p>
                <div class="flex justify-end md:justify-start">
                    <a
                        href="/artists/nina"
                        class="inline-flex items-center text-sm font-medium hover:text-neutral-300 transition-colors border-b border-neutral-700 pb-1"
                    >
                        View Nina's Portfolio <ArrowRight
                            className="ml-2 w-4 h-4"
                        />
                    </a>
                </div>
            </div>
        </div>

        <!-- Artist: Karli -->
        <div
            class="flex flex-col md:flex-row items-center gap-12 reveal-hidden group"
        >
            <div
                class="w-full md:w-1/2 relative aspect-[4/5] md:aspect-square overflow-hidden rounded-2xl"
            >
                <img
                    src="/artists/karli.png"
                    alt="Karli Portfolio"
                    class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105 filter grayscale group-hover:grayscale-0"
                />
            </div>
            <div class="w-full md:w-1/2 md:pl-12">
                <div class="flex items-center gap-4 mb-2">
                    <span class="h-px w-8 bg-neutral-700"></span>
                    <span
                        class="text-xs font-medium tracking-widest uppercase text-neutral-500"
                        >Neo Traditional & Color</span
                    >
                </div>
                <h4
                    class="text-5xl md:text-7xl font-medium tracking-tighter text-white mb-6"
                >
                    Karli.
                </h4>
                <p
                    class="text-neutral-400 text-lg font-light leading-relaxed mb-8 max-w-md"
                >
                    Vibrant, bold, and timeless. Karli reinvents traditional
                    motifs with a modern palette. If you want art that speaks
                    loudly and holds its vibrancy for decades, Karli is the
                    choice.
                </p>
                <a
                    href="/artists/karli"
                    class="inline-flex items-center text-sm font-medium hover:text-neutral-300 transition-colors border-b border-neutral-700 pb-1"
                >
                    View Karli's Portfolio <ArrowRight
                        className="ml-2 w-4 h-4"
                    />
                </a>
            </div>
        </div>
    </div>
</section>
