---
// Cuba Tattoo Studio Hero Section
---

<section id="hero-section" class="relative min-h-screen bg-gradient-to-br from-black via-gray-900 to-black overflow-hidden">
  <!-- Background Pattern -->
  <div class="absolute inset-0 opacity-10">
    <div class="absolute inset-0 bg-gradient-to-br from-amber-400/5 via-transparent to-amber-400/5"></div>
  </div>

  <!-- Main Content -->
  <div class="relative z-10 flex flex-col min-h-screen">
    <!-- Navigation Header -->
    <header class="flex justify-between items-center p-6 md:p-8">
      <div class="flex items-center space-x-3">
        <div class="w-10 h-10 bg-amber-400 rounded-full flex items-center justify-center">
          <span class="text-black font-bold text-xl">C</span>
        </div>
        <span class="text-white font-bold text-xl tracking-wider">CUBA TATTOO</span>
      </div>
      
      <!-- Desktop Navigation -->
      <nav class="hidden md:flex items-center space-x-8">
        <a href="#gallery" class="text-white hover:text-amber-400 transition-colors font-medium scroll-animate" data-animation="fadeIn" data-delay="0.2">Galería</a>
        <a href="#services" class="text-white hover:text-amber-400 transition-colors font-medium scroll-animate" data-animation="fadeIn" data-delay="0.3">Servicios</a>
        <a href="#artists" class="text-white hover:text-amber-400 transition-colors font-medium scroll-animate" data-animation="fadeIn" data-delay="0.4">Artistas</a>
        <a href="#contact" class="bg-amber-400 text-black px-6 py-2 rounded-full hover:bg-amber-300 transition-colors font-semibold scroll-animate" data-animation="fadeIn" data-delay="0.5">Contacto</a>
      </nav>

      <!-- Mobile Menu Button -->
      <button class="md:hidden text-white p-2">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </header>

    <!-- Hero Content -->
    <div class="flex-1 flex items-center justify-center px-6 md:px-8">
      <div class="text-center max-w-4xl mx-auto">
        <h1 class="text-5xl md:text-7xl lg:text-8xl font-bold text-white mb-6 leading-tight scroll-animate" data-animation="fadeIn" data-delay="0.1">
          ARTE EN TU
          <span class="text-amber-400 block">PIEL</span>
        </h1>
        
        <p class="text-xl md:text-2xl text-gray-300 mb-8 max-w-2xl mx-auto leading-relaxed scroll-animate" data-animation="fadeIn" data-delay="0.3">
          Transforma tus ideas en obras de arte permanentes. Diseños únicos, técnicas profesionales y la mejor experiencia en tatuajes en Cuba.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 justify-center items-center scroll-animate" data-animation="fadeIn" data-delay="0.5">
          <a href="#contact" class="bg-amber-400 text-black px-8 py-4 rounded-full font-bold text-lg hover:bg-amber-300 transition-all duration-300 hover:scale-105 shadow-lg">
            Reservar Cita
          </a>
          <a href="#gallery" class="border-2 border-white text-white px-8 py-4 rounded-full font-bold text-lg hover:bg-white hover:text-black transition-all duration-300 hover:scale-105">
            Ver Trabajos
          </a>
        </div>

        <!-- Features -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mt-16 scroll-animate" data-animation="fadeIn" data-delay="0.7">
          <div class="text-center">
            <div class="w-16 h-16 bg-amber-400/20 rounded-full flex items-center justify-center mx-auto mb-4">
              <svg class="w-8 h-8 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path>
              </svg>
            </div>
            <h3 class="text-white font-bold text-lg mb-2">Diseños Únicos</h3>
            <p class="text-gray-400">Cada tatuaje es una obra de arte personalizada</p>
          </div>
          
          <div class="text-center">
            <div class="w-16 h-16 bg-amber-400/20 rounded-full flex items-center justify-center mx-auto mb-4">
              <svg class="w-8 h-8 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
            </div>
            <h3 class="text-white font-bold text-lg mb-2">Técnicas Profesionales</h3>
            <p class="text-gray-400">Equipos de última generación y máxima higiene</p>
          </div>
          
          <div class="text-center">
            <div class="w-16 h-16 bg-amber-400/20 rounded-full flex items-center justify-center mx-auto mb-4">
              <svg class="w-8 h-8 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
              </svg>
            </div>
            <h3 class="text-white font-bold text-lg mb-2">Experiencia Única</h3>
            <p class="text-gray-400">Atención personalizada en ambiente cómodo</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Scroll Indicator -->
    <div class="text-center pb-8 scroll-animate" data-animation="fadeIn" data-delay="1">
      <div class="inline-flex flex-col items-center text-amber-400">
        <span class="text-sm font-medium mb-2 tracking-wider">EXPLORA NUESTRO TRABAJO</span>
        <svg class="w-6 h-6 animate-bounce" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
        </svg>
      </div>
    </div>
  </div>
</section>

<style>
  /* Custom animations for hero section */
  @keyframes float {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(-10px); }
  }

  .float-animation {
    animation: float 3s ease-in-out infinite;
  }

  /* Smooth hover transitions */
  .hover-glow:hover {
    box-shadow: 0 0 30px rgba(251, 191, 36, 0.3);
    transition: all 0.3s ease;
  }
</style>

<script>
  import { gsap } from "gsap"
  import { ScrollTrigger } from "gsap/ScrollTrigger"

  function initHeroAnimations() {
    gsap.registerPlugin(ScrollTrigger)

    // Hero entrance animation
    const heroElements = {
      logo: document.querySelector('header'),
      title: document.querySelector('h1'),
      subtitle: document.querySelector('p'),
      buttons: document.querySelectorAll('a[href="#contact"], a[href="#gallery"]'),
      features: document.querySelectorAll('.grid > div'),
      scrollIndicator: document.querySelector('.inline-flex')
    }

    // Initial states
    gsap.set([heroElements.logo, heroElements.title, heroElements.subtitle], { 
      opacity: 0, 
      y: 30 
    })
    gsap.set(heroElements.buttons, { 
      opacity: 0, 
      scale: 0.8 
    })
    gsap.set(heroElements.features, { 
      opacity: 0, 
      y: 50 
    })
    gsap.set(heroElements.scrollIndicator, { 
      opacity: 0 
    })

    // Main hero timeline
    const heroTl = gsap.timeline({ delay: 0.5 })

    heroTl
      .to(heroElements.logo, { 
        opacity: 1, 
        y: 0, 
        duration: 0.8, 
        ease: "power2.out" 
      })
      .to(heroElements.title, { 
        opacity: 1, 
        y: 0, 
        duration: 1, 
        ease: "power2.out" 
      }, "-=0.4")
      .to(heroElements.subtitle, { 
        opacity: 1, 
        y: 0, 
        duration: 0.8, 
        ease: "power2.out" 
      }, "-=0.6")
      .to(heroElements.buttons, { 
        opacity: 1, 
        scale: 1, 
        duration: 0.6, 
        stagger: 0.1, 
        ease: "back.out(1.7)" 
      }, "-=0.4")
      .to(heroElements.features, { 
        opacity: 1, 
        y: 0, 
        duration: 0.8, 
        stagger: 0.2, 
        ease: "power2.out" 
      }, "-=0.2")
      .to(heroElements.scrollIndicator, { 
        opacity: 1, 
        duration: 0.5 
      }, "-=0.5")

    // Parallax effect for hero background
    gsap.to("#hero-section", {
      yPercent: -50,
      ease: "none",
      scrollTrigger: {
        trigger: "#hero-section",
        start: "top top",
        end: "200% top",
        scrub: true,
        markers: false
      }
    })

    // Button hover animations
    const buttons = document.querySelectorAll('a[href="#contact"], a[href="#gallery"]')
    buttons.forEach(button => {
      button.addEventListener('mouseenter', () => {
        gsap.to(button, { scale: 1.05, duration: 0.3, ease: "power2.out" })
      })
      button.addEventListener('mouseleave', () => {
        gsap.to(button, { scale: 1, duration: 0.3, ease: "power2.out" })
      })
    })

    console.log("Hero animations initialized for Cuba Tattoo Studio")
  }

  // Initialize when DOM is ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initHeroAnimations)
  } else {
    initHeroAnimations()
  }

  // Re-initialize for Astro navigation
  document.addEventListener('astro:page-load', initHeroAnimations)
</script>
