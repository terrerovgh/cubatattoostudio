---
import { ArrowRight } from "lucide-react";
import { getWorksByLocation, getSiteContent } from "../lib/content-helpers";

const galleryWorks = await getWorksByLocation("main_gallery");

// Create a flat list of images with their work details for linking/alt text
const galleryImages = galleryWorks.flatMap((work) =>
    work.data.images.map((img) => ({
        src: img,
        alt: work.data.title,
        slug: work.slug,
    })),
);

// Fetch gallery content from database with fallbacks
const galleryData = await getSiteContent("gallery");
const galleryContent = galleryData?.content || {};

const title = galleryContent.title || "Selected Works.";
const archiveText = galleryContent.archive_text || "View Archive";
const archiveLink = galleryContent.archive_link || "/works";
---

<section id="gallery" class="py-32 bg-black">
    <div class="max-w-7xl mx-auto px-6">
        <div class="flex justify-between items-end mb-16 reveal-hidden">
            <h3
                class="text-3xl md:text-4xl font-medium tracking-tighter text-white"
            >
                {title}
            </h3>
            <a
                href={archiveLink}
                class="hidden md:inline-flex items-center text-sm font-medium text-neutral-500 hover:text-white transition-colors"
            >
                {archiveText}
                <ArrowRight className="ml-2 w-4 h-4" />
            </a>
        </div>

        <!-- Masonry Grid -->
        <div class="columns-1 md:columns-2 lg:columns-3 gap-6 space-y-6">
            {
                galleryImages.map((image, index) => (
                    <div
                        class={`break-inside-avoid reveal-hidden ${index % 3 === 1 ? "stagger-delay-1" : index % 3 === 2 ? "stagger-delay-2" : ""}`}
                    >
                        <a href={`/works/${image.slug}`}>
                            <img
                                src={image.src}
                                class="w-full rounded-xl hover:opacity-90 transition-opacity"
                                alt={image.alt}
                            />
                        </a>
                    </div>
                ))
            }
        </div>

        <div class="mt-8 text-center md:hidden">
            <a
                href={archiveLink}
                class="inline-flex items-center text-sm font-medium text-neutral-500 hover:text-white transition-colors"
            >
                {archiveText}
                <ArrowRight className="ml-2 w-4 h-4" />
            </a>
        </div>
    </div>
</section>
