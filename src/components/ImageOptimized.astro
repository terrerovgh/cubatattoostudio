---
import { Img } from 'astro-imagetools/components';

export interface Props {
  src: string;
  alt: string;
  width?: number;
  height?: number;
  class?: string;
  loading?: 'lazy' | 'eager';
  format?: string[];
  quality?: number;
}

const { 
  src, 
  alt, 
  width, 
  height, 
  class: className = '', 
  loading = 'lazy',
  format = ['avif', 'webp'],
  quality = 80,
  ...rest 
} = Astro.props;
---

<Img
  src={src}
  alt={alt}
  width={width}
  height={height}
  class={className}
  loading={loading}
  format={format}
  quality={quality}
  {...rest}
/>
