---
import { Instagram, Twitter, Facebook } from "lucide-react";
---

<footer class="py-12 bg-black border-t border-neutral-900">
    <div
        class="max-w-7xl mx-auto px-6 flex flex-col md:flex-row justify-between items-center"
    >
        <div class="mb-4 md:mb-0">
            <span
                class="text-lg font-medium tracking-tighter uppercase text-white"
                >Cuba Tattoo Studio</span
            >
            <p class="text-xs text-neutral-500 mt-1">
                © 2025 Cuba Tattoo Studio. Albuquerque, NM.
            </p>
        </div>

        <div class="flex space-x-6">
            <a
                href="#"
                class="text-neutral-400 hover:text-white transition-colors"
                ><Instagram className="w-5 h-5" /></a
            >
            <a
                href="#"
                class="text-neutral-400 hover:text-white transition-colors"
                ><Twitter className="w-5 h-5" /></a
            >
            <a
                href="#"
                class="text-neutral-400 hover:text-white transition-colors"
                ><Facebook className="w-5 h-5" /></a
            >
        </div>
    </div>
</footer>
