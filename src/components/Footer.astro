---
import LogoVI from "@/assets/logo-vi.svg"
---

<footer class="bg-black border-t border-gray-800 py-12 px-8">
  <div class="max-w-7xl mx-auto">
    <div class="grid md:grid-cols-4 gap-8">
      <!-- Logo y Descripción -->
      <div class="md:col-span-2">
        <div class="flex items-center mb-4">
          <LogoVI class="size-8 text-amber-400 mr-3" />
          <h3 class="text-2xl font-bold text-white">Cuba Tattoo Studio</h3>
        </div>
        <p class="text-gray-300 leading-relaxed max-w-md">
          El arte del tatuaje en el corazón de Cuba. Creamos experiencias únicas que duran para toda la vida, combinando tradición cubana con técnicas modernas de primer nivel.
        </p>
        <div class="flex space-x-4 mt-6">
          <button class="w-10 h-10 bg-gray-800 rounded-full flex items-center justify-center hover:bg-amber-400 hover:text-black transition-colors duration-300">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M24 4.557c-.883.392-1.832.656-2.828.775 1.017-.609 1.798-1.574 2.165-2.724-.951.564-2.005.974-3.127 1.195-.897-.957-2.178-1.555-3.594-1.555-3.179 0-5.515 2.966-4.797 6.045-4.091-.205-7.719-2.165-10.148-5.144-1.29 2.213-.669 5.108 1.523 6.574-.806-.026-1.566-.247-2.229-.616-.054 2.281 1.581 4.415 3.949 4.89-.693.188-1.452.232-2.224.084.626 1.956 2.444 3.379 4.6 3.419-2.07 1.623-4.678 2.348-7.29 2.04 2.179 1.397 4.768 2.212 7.548 2.212 9.142 0 14.307-7.721 13.995-14.646.962-.695 1.797-1.562 2.457-2.549z"/>
            </svg>
          </button>
          <button class="w-10 h-10 bg-gray-800 rounded-full flex items-center justify-center hover:bg-amber-400 hover:text-black transition-colors duration-300">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
          </button>
          <button class="w-10 h-10 bg-gray-800 rounded-full flex items-center justify-center hover:bg-amber-400 hover:text-black transition-colors duration-300">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M9 8h-3v4h3v12h5v-12h3.642l.358-4h-4v-1.667c0-.955.192-1.333 1.115-1.333h2.885v-5h-3.808c-3.596 0-5.192 1.583-5.192 4.615v3.385z"/>
            </svg>
          </button>
        </div>
      </div>

      <!-- Enlaces Rápidos -->
      <div>
        <h4 class="text-lg font-semibold text-white mb-4">Enlaces Rápidos</h4>
        <ul class="space-y-2">
          <li><a href="#gallery" class="text-gray-300 hover:text-amber-400 transition-colors duration-300">Galería</a></li>
          <li><a href="#services" class="text-gray-300 hover:text-amber-400 transition-colors duration-300">Servicios</a></li>
          <li><a href="#artists" class="text-gray-300 hover:text-amber-400 transition-colors duration-300">Artistas</a></li>
          <li><a href="#contact" class="text-gray-300 hover:text-amber-400 transition-colors duration-300">Contacto</a></li>
          <li><a href="#cuidados" class="text-gray-300 hover:text-amber-400 transition-colors duration-300">Cuidados</a></li>
          <li><a href="#precios" class="text-gray-300 hover:text-amber-400 transition-colors duration-300">Precios</a></li>
        </ul>
      </div>

      <!-- Información de Contacto -->
      <div>
        <h4 class="text-lg font-semibold text-white mb-4">Contacto</h4>
        <div class="space-y-2 text-gray-300">
          <p class="flex items-center">
            <svg class="w-4 h-4 mr-2 text-amber-400" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
            </svg>
            Calle 23 #456, Vedado
          </p>
          <p class="flex items-center">
            <svg class="w-4 h-4 mr-2 text-amber-400" fill="currentColor" viewBox="0 0 24 24">
              <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
            </svg>
            +53 7 832-1234
          </p>
          <p class="flex items-center">
            <svg class="w-4 h-4 mr-2 text-amber-400" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.89 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/>
            </svg>
            info@cubatattoostudio.com
          </p>
        </div>
        
        <div class="mt-4">
          <h5 class="text-white font-medium mb-2">Horarios</h5>
          <p class="text-gray-300 text-sm">
            Lun - Vie: 10:00 AM - 8:00 PM<br>
            Sábados: 10:00 AM - 6:00 PM<br>
            Domingos: Cerrado
          </p>
        </div>
      </div>
    </div>

    <!-- Línea divisoria -->
    <div class="border-t border-gray-800 mt-8 pt-8">
      <div class="flex flex-col md:flex-row justify-between items-center">
        <p class="text-gray-400 text-sm">
          © 2025 Cuba Tattoo Studio. Todos los derechos reservados.
        </p>
        <div class="flex space-x-6 mt-4 md:mt-0">
          <a href="#privacy" class="text-gray-400 text-sm hover:text-amber-400 transition-colors duration-300">
            Política de Privacidad
          </a>
          <a href="#terms" class="text-gray-400 text-sm hover:text-amber-400 transition-colors duration-300">
            Términos de Servicio
          </a>
          <a href="#cookies" class="text-gray-400 text-sm hover:text-amber-400 transition-colors duration-300">
            Política de Cookies
          </a>
        </div>
      </div>
    </div>
  </div>
</footer>
