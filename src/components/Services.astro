---
import { PenTool, Pencil, Feather } from "lucide-react";
import { getCollection } from "astro:content";
import { getWorksByLocation, getSiteContent } from "../lib/content-helpers";

// Fetch services from content collection
const services = await getCollection("services");

// Map icon strings to components
const iconMap: Record<string, any> = {
    PenTool: PenTool,
    Pencil: Pencil,
    Feather: Feather,
};

// Helper to get a random work image for a specific style/category
async function getServiceImage(service: any) {
    // First try to get a dynamic image from works
    const works = await getWorksByLocation(service.data.relatedTag);
    if (works.length > 0) {
        return works[0].data.images[0];
    }
    // Fallback to the coverImage defined in the service content
    return service.data.coverImage;
}

// Prepare service data with images
const servicesWithImages = await Promise.all(
    services.map(async (service) => {
        const image = await getServiceImage(service);
        return {
            ...service,
            image,
            Icon: service.data.icon ? iconMap[service.data.icon] : PenTool,
        };
    }),
);

// Fetch services content from database with fallbacks
const servicesData = await getSiteContent("services");
const servicesContent = servicesData?.content || {};

const title = servicesContent.title || "Disciplines.";
const description =
    servicesContent.description ||
    "We don't just apply ink. We curate experiences tailored to your narrative. From microscopic detail to full body suits.";
---

<section id="services" class="py-32 bg-black">
    <div class="max-w-7xl mx-auto px-6">
        <div class="mb-24 reveal-hidden">
            <h3
                class="text-3xl md:text-5xl font-medium tracking-tighter mb-6 text-white"
            >
                {title}
            </h3>
            <p class="text-lg text-neutral-400 font-light max-w-2xl">
                {description}
            </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            {
                servicesWithImages.map((service, index) => (
                    <div
                        class={`group relative h-[400px] rounded-2xl overflow-hidden reveal-hidden stagger-delay-${index + 1} cursor-default`}
                    >
                        <div class="absolute inset-0 bg-neutral-900 transition-transform duration-700 group-hover:scale-[1.02]">
                            <img
                                src={service.image}
                                class="w-full h-full object-cover opacity-50 grayscale group-hover:grayscale-0 transition-all duration-700"
                                alt={service.data.title}
                            />
                        </div>
                        <div class="absolute inset-0 p-8 flex flex-col justify-end bg-gradient-to-t from-black/60 to-transparent">
                            <service.Icon className="text-white w-8 h-8 mb-4 opacity-0 group-hover:opacity-100 transform translate-y-4 group-hover:translate-y-0 transition-all duration-500" />
                            <h4 class="text-2xl text-white font-medium tracking-tight mb-2">
                                {service.data.title}
                            </h4>
                            <p class="text-neutral-300 text-sm font-light opacity-0 group-hover:opacity-100 transform translate-y-4 group-hover:translate-y-0 transition-all duration-500 delay-100">
                                {service.data.description}
                            </p>
                        </div>
                    </div>
                ))
            }
        </div>
    </div>
</section>
