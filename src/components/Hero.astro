---
import { ArrowDown } from "lucide-react";
import DomeGallery from "./DomeGallery";
import { getWorksByLocation, getSiteContent } from "../lib/content-helpers";

const domeWorks = await getWorksByLocation("dome_gallery");

// Flatten all images from the featured works
const domeImages = domeWorks.flatMap((work) => work.data.images);

// Fetch hero content from database with fallbacks
const heroData = await getSiteContent("hero");
const heroContent = heroData?.content || {};

const location = heroContent.location || "Albuquerque, NM";
const tagline =
    heroContent.tagline ||
    "Ideally located in the heart of the desert. Where precision meets permanence.";
const ctaText = heroContent.cta_text || "Meet the Artists";
const ctaLink = heroContent.cta_link || "#artists";
---

<section
    class="relative h-screen flex items-center justify-center overflow-hidden"
>
    <!-- Parallax Background Image -->
    <!-- Dome Gallery Background -->
    <div class="absolute inset-0 w-full h-full z-0">
        <DomeGallery client:load images={domeImages} />
    </div>
    <div
        class="absolute inset-0 bg-gradient-to-b from-black/20 via-transparent to-black z-10"
    >
    </div>

    <div class="relative z-20 text-center px-4 max-w-4xl mx-auto">
        <h2
            class="reveal-hidden text-xs md:text-sm font-medium tracking-[0.2em] uppercase text-neutral-400 mb-6"
        >
            {location}
        </h2>
        <h1 class="sr-only">Cuba Tattoo Studio</h1>
        <div class="reveal-hidden stagger-delay-1 mb-12">
            <img
                src="/logo-stack.svg"
                alt="Cuba Tattoo Studio"
                class="w-full max-w-lg md:max-w-2xl mx-auto opacity-90"
            />
        </div>
        <p
            class="reveal-hidden stagger-delay-2 text-lg md:text-xl text-neutral-300 max-w-lg mx-auto font-light tracking-tight mb-10"
        >
            {tagline}
        </p>
        <div class="reveal-hidden stagger-delay-3">
            <a
                href={ctaLink}
                class="inline-flex items-center justify-center px-8 py-3 text-sm font-medium text-neutral-900 bg-white/30 backdrop-blur-md border border-white/20 rounded-full hover:bg-white/20 transition-all duration-300 group"
            >
                {ctaText}
                <ArrowDown
                    className="ml-2 w-4 h-4 group-hover:translate-y-1 transition-transform"
                />
            </a>
        </div>
    </div>
</section>
