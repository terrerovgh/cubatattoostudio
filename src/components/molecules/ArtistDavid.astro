---
import ImageOptimized from '../atoms/ImageOptimized.astro';
import Button from '../atoms/Button.astro';
import Heading from '../atoms/Heading.astro';

interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;
---

<div class={`artist-card group relative overflow-hidden rounded-2xl bg-gradient-to-br from-gray-900 to-black border border-gray-800 hover:border-amber-400/50 transition-all duration-500 ${className}`}>
  <!-- Background with overlay -->
  <div class="absolute inset-0 bg-gradient-to-t from-black via-black/50 to-transparent z-10"></div>
  
  <!-- Artist Image -->
  <div class="relative h-96 md:h-[500px] overflow-hidden">
    <ImageOptimized
      src="/artists/david/artist-david.jpg"
      alt="David - Especialista en Tatuajes Realistas"
      width={400}
      height={500}
      class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700 ease-out"
      loading="lazy"
    />
  </div>
  
  <!-- Content -->
  <div class="absolute bottom-0 left-0 right-0 p-6 md:p-8 z-20">
    <!-- Artist Name -->
    <Heading level={3} size="2xl" variant="primary" class="mb-2">
      David
    </Heading>
    
    <!-- Specialty -->
    <p class="text-amber-400 font-semibold text-lg mb-3">
      Especialista en Realismo
    </p>
    
    <!-- Description -->
    <p class="text-gray-300 text-sm md:text-base mb-4 line-clamp-3 group-hover:line-clamp-none transition-all duration-300">
      Más de 8 años de experiencia en tatuajes realistas y retratos. 
      David domina las técnicas de sombreado y detalle que dan vida a cada diseño. 
      Especializado en retratos, animales y naturaleza muerta con un nivel de detalle excepcional.
    </p>
    
    <!-- Specialties List -->
    <div class="flex flex-wrap gap-2 mb-4">
      <span class="px-3 py-1 bg-amber-400/10 text-amber-400 text-xs rounded-full border border-amber-400/20">
        Retratos
      </span>
      <span class="px-3 py-1 bg-amber-400/10 text-amber-400 text-xs rounded-full border border-amber-400/20">
        Realismo
      </span>
      <span class="px-3 py-1 bg-amber-400/10 text-amber-400 text-xs rounded-full border border-amber-400/20">
        Animales
      </span>
      <span class="px-3 py-1 bg-amber-400/10 text-amber-400 text-xs rounded-full border border-amber-400/20">
        Naturaleza Muerta
      </span>
    </div>
    
    <!-- Stats -->
    <div class="grid grid-cols-3 gap-4 mb-6 text-center">
      <div>
        <div class="text-amber-400 font-bold text-lg">8+</div>
        <div class="text-gray-400 text-xs">Años</div>
      </div>
      <div>
        <div class="text-amber-400 font-bold text-lg">500+</div>
        <div class="text-gray-400 text-xs">Tatuajes</div>
      </div>
      <div>
        <div class="text-amber-400 font-bold text-lg">★ 4.9</div>
        <div class="text-gray-400 text-xs">Rating</div>
      </div>
    </div>
    
    <!-- Action Buttons -->
    <div class="flex gap-3">
      <Button variant="primary" size="sm" class="flex-1">
        Ver Portfolio
      </Button>
      <Button variant="outline" size="sm" class="flex-1">
        Reservar Cita
      </Button>
    </div>
  </div>
  
  <!-- Hover Effects -->
  <div class="absolute inset-0 bg-gradient-to-t from-amber-400/20 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 z-5"></div>
</div>

<style>
  .artist-card {
    transform: translateY(0);
    transition: transform 0.3s ease-out, box-shadow 0.3s ease-out;
  }
  
  .artist-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 20px 40px rgba(251, 191, 36, 0.15);
  }
  
  /* Line clamp utility */
  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  
  .line-clamp-none {
    display: block;
    -webkit-line-clamp: none;
  }
</style>
