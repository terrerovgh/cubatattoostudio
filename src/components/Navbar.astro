---
import { Menu } from 'lucide-react';
---

<nav
    id="main-navbar"
    class="fixed w-full z-50 top-0 start-0 transition-all duration-300 border-b border-transparent"
>
    <div class="max-w-7xl mx-auto flex flex-wrap items-center justify-between px-6 py-4">
        <a href="/" class="flex items-center space-x-1 rtl:space-x-reverse z-50">
            <img src="/logo-stack.svg" alt="Cuba Tattoo Studio" class="h-10 md:h-12 w-auto" />
        </a>
        <div class="flex md:order-2 space-x-3 md:space-x-0 rtl:space-x-reverse z-50">
            <a
                href="#booking"
                class="text-xs font-medium px-5 py-2.5 text-center rounded-full bg-white text-black hover:bg-neutral-200 transition-all duration-300 transform hover:scale-105 active:scale-95 shadow-[0_0_15px_rgba(255,255,255,0.1)]"
            >
                Book Session
            </a>
            <button
                data-collapse-toggle="navbar-sticky"
                type="button"
                class="inline-flex items-center p-2 w-10 h-10 justify-center text-sm text-neutral-400 hover:bg-neutral-800 rounded-lg md:hidden focus:outline-none transition-colors"
                aria-controls="navbar-sticky"
                aria-expanded="false"
            >
                <span class="sr-only">Open main menu</span>
                <Menu className="w-6 h-6" />
            </button>
        </div>
        <div
            class="items-center justify-between hidden w-full md:flex md:w-auto md:order-1 fixed inset-0 top-0 bg-black/95 backdrop-blur-xl md:static md:bg-transparent md:backdrop-blur-none z-40 transition-all duration-300"
            id="navbar-sticky"
        >
            <ul
                class="flex flex-col p-4 md:p-0 font-medium h-full justify-center items-center md:h-auto md:justify-start md:flex-row md:space-x-8 rtl:space-x-reverse"
            >
                <li>
                    <a
                        href="#services"
                        class="block py-4 px-3 text-2xl md:text-sm text-neutral-300 rounded hover:text-white transition-colors tracking-tight md:py-2"
                        >Services</a
                    >
                </li>
                <li>
                    <a
                        href="#artists"
                        class="block py-4 px-3 text-2xl md:text-sm text-neutral-300 rounded hover:text-white transition-colors tracking-tight md:py-2"
                        >Artists</a
                    >
                </li>
                <li>
                    <a
                        href="#gallery"
                        class="block py-4 px-3 text-2xl md:text-sm text-neutral-300 rounded hover:text-white transition-colors tracking-tight md:py-2"
                        >Gallery</a
                    >
                </li>
                <li>
                    <a
                        href="#contact"
                        class="block py-4 px-3 text-2xl md:text-sm text-neutral-300 rounded hover:text-white transition-colors tracking-tight md:py-2"
                        >Studio</a
                    >
                </li>
            </ul>
        </div>
    </div>
</nav>

<script>
    // Navbar Scroll Effect
    const navbar = document.getElementById('main-navbar');

    const updateNavbar = () => {
        if (window.scrollY > 50) {
            navbar?.classList.add('bg-black/80', 'backdrop-blur-md', 'border-white/5');
        } else {
            navbar?.classList.remove('bg-black/80', 'backdrop-blur-md', 'border-white/5');
        }
    };

    window.addEventListener('scroll', updateNavbar);
    updateNavbar(); // Init

    // Mobile Menu Link Click Handling
    const mobileMenu = document.getElementById('navbar-sticky');
    const menuLinks = mobileMenu?.querySelectorAll('a');
    const toggleBtn = document.querySelector('[data-collapse-toggle]');

    menuLinks?.forEach((link) => {
        link.addEventListener('click', () => {
            if (window.innerWidth < 768) {
                // Only on mobile
                mobileMenu?.classList.add('hidden');
                toggleBtn?.setAttribute('aria-expanded', 'false');
            }
        });
    });
</script>
