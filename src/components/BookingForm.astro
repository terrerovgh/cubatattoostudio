---
import Heading from './Heading.astro';
import Button from './Button.astro';

export interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;
---

<section class={`py-20 bg-white ${className}`}>
  <div class="container mx-auto px-4">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-12">
        <Heading level={2} class="mb-4">
          Reserva tu Cita
        </Heading>
        <p class="text-xl text-gray-600">
          Completa el formulario y nos pondremos en contacto contigo para confirmar tu cita
        </p>
      </div>

      <form class="space-y-6" id="booking-form">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <!-- Personal Information -->
          <div>
            <label for="name" class="block text-sm font-medium text-gray-700 mb-2">
              Nombre Completo *
            </label>
            <input
              type="text"
              id="name"
              name="name"
              required
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-red-500 focus:border-red-500"
              placeholder="Tu nombre completo"
            />
          </div>

          <div>
            <label for="email" class="block text-sm font-medium text-gray-700 mb-2">
              Correo Electrónico *
            </label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-red-500 focus:border-red-500"
              placeholder="tu@email.com"
            />
          </div>

          <div>
            <label for="phone" class="block text-sm font-medium text-gray-700 mb-2">
              Teléfono *
            </label>
            <input
              type="tel"
              id="phone"
              name="phone"
              required
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-red-500 focus:border-red-500"
              placeholder="+53 5555 1234"
            />
          </div>

          <div>
            <label for="artist" class="block text-sm font-medium text-gray-700 mb-2">
              Artista Preferido
            </label>
            <select
              id="artist"
              name="artist"
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-red-500 focus:border-red-500"
            >
              <option value="">Seleccionar artista</option>
              <option value="david">David - Realismo</option>
              <option value="nina">Nina - Tradicional</option>
              <option value="karli">Karli - Fine Line</option>
              <option value="any">Cualquier artista disponible</option>
            </select>
          </div>
        </div>

        <!-- Tattoo Information -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div>
            <label for="style" class="block text-sm font-medium text-gray-700 mb-2">
              Estilo de Tatuaje
            </label>
            <select
              id="style"
              name="style"
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-red-500 focus:border-red-500"
            >
              <option value="">Seleccionar estilo</option>
              <option value="realismo">Realismo</option>
              <option value="tradicional">Tradicional</option>
              <option value="fine-line">Fine Line</option>
              <option value="geometrico">Geométrico</option>
              <option value="color">Color</option>
              <option value="blackwork">Blackwork</option>
              <option value="otro">Otro</option>
            </select>
          </div>

          <div>
            <label for="size" class="block text-sm font-medium text-gray-700 mb-2">
              Tamaño Estimado
            </label>
            <select
              id="size"
              name="size"
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-red-500 focus:border-red-500"
            >
              <option value="">Seleccionar tamaño</option>
              <option value="small">Pequeño (menos de 5cm)</option>
              <option value="medium">Mediano (5-15cm)</option>
              <option value="large">Grande (15-25cm)</option>
              <option value="extra-large">Extra Grande (más de 25cm)</option>
            </select>
          </div>
        </div>

        <div>
          <label for="placement" class="block text-sm font-medium text-gray-700 mb-2">
            Ubicación en el Cuerpo
          </label>
          <input
            type="text"
            id="placement"
            name="placement"
            class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-red-500 focus:border-red-500"
            placeholder="Ej: brazo, pierna, espalda..."
          />
        </div>

        <div>
          <label for="description" class="block text-sm font-medium text-gray-700 mb-2">
            Descripción del Tatuaje *
          </label>
          <textarea
            id="description"
            name="description"
            rows="5"
            required
            class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-red-500 focus:border-red-500"
            placeholder="Describe tu idea de tatuaje, incluye detalles, referencias, etc..."
          ></textarea>
        </div>

        <!-- Reference Images -->
        <div>
          <label for="references" class="block text-sm font-medium text-gray-700 mb-2">
            Imágenes de Referencia
          </label>
          <div class="border-2 border-dashed border-gray-300 rounded-lg p-6 text-center">
            <input
              type="file"
              id="references"
              name="references"
              multiple
              accept="image/*"
              class="hidden"
            />
            <label for="references" class="cursor-pointer">
              <div class="text-gray-500">
                <svg class="mx-auto h-12 w-12 mb-2" stroke="currentColor" fill="none" viewBox="0 0 48 48">
                  <path d="M28 8H12a4 4 0 00-4 4v20m32-12v8m0 0v8a4 4 0 01-4 4H12a4 4 0 01-4-4v-4m32-4l-3.172-3.172a4 4 0 00-5.656 0L28 28M8 32l9.172-9.172a4 4 0 015.656 0L28 28m0 0l4 4m4-24h8m-4-4v8m-12 4h.02" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
                <p>Haz clic para subir imágenes de referencia</p>
                <p class="text-sm">PNG, JPG hasta 10MB cada una</p>
              </div>
            </label>
          </div>
        </div>

        <!-- Preferred Date -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div>
            <label for="preferred-date" class="block text-sm font-medium text-gray-700 mb-2">
              Fecha Preferida
            </label>
            <input
              type="date"
              id="preferred-date"
              name="preferred-date"
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-red-500 focus:border-red-500"
            />
          </div>

          <div>
            <label for="budget" class="block text-sm font-medium text-gray-700 mb-2">
              Presupuesto Estimado (CUP)
            </label>
            <select
              id="budget"
              name="budget"
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-red-500 focus:border-red-500"
            >
              <option value="">Seleccionar rango</option>
              <option value="under-5000">Menos de 5,000 CUP</option>
              <option value="5000-10000">5,000 - 10,000 CUP</option>
              <option value="10000-20000">10,000 - 20,000 CUP</option>
              <option value="over-20000">Más de 20,000 CUP</option>
            </select>
          </div>
        </div>

        <!-- Additional Notes -->
        <div>
          <label for="notes" class="block text-sm font-medium text-gray-700 mb-2">
            Notas Adicionales
          </label>
          <textarea
            id="notes"
            name="notes"
            rows="3"
            class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-red-500 focus:border-red-500"
            placeholder="Alergias, preferencias de horario, etc..."
          ></textarea>
        </div>

        <!-- Terms and Conditions -->
        <div class="flex items-start">
          <input
            type="checkbox"
            id="terms"
            name="terms"
            required
            class="mt-1 h-4 w-4 text-red-600 focus:ring-red-500 border-gray-300 rounded"
          />
          <label for="terms" class="ml-2 text-sm text-gray-600">
            Acepto los <a href="/terms" class="text-red-600 hover:text-red-800">términos y condiciones</a> 
            y la <a href="/privacy" class="text-red-600 hover:text-red-800">política de privacidad</a> *
          </label>
        </div>

        <!-- Submit Button -->
        <div class="text-center">
          <Button 
            type="submit" 
            variant="primary" 
            size="lg"
            class="bg-red-600 hover:bg-red-700 border-none px-8"
          >
            Enviar Solicitud de Cita
          </Button>
        </div>
      </form>
    </div>
  </div>
</section>

<script>
  document.getElementById('booking-form')?.addEventListener('submit', function(e) {
    e.preventDefault();
    
    // Here you would typically send the form data to your backend
    // For now, we'll just show a success message
    alert('¡Gracias por tu solicitud! Nos pondremos en contacto contigo pronto.');
    
    // Reset form
    this.reset();
  });

  // Handle file upload preview
  document.getElementById('references')?.addEventListener('change', function(e) {
    const files = e.target.files;
    if (files && files.length > 0) {
      const label = e.target.parentElement.querySelector('label div');
      if (label) {
        label.innerHTML = `<p>${files.length} archivo(s) seleccionado(s)</p>`;
      }
    }
  });
</script>
