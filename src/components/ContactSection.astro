---
---

<section id="contact" class="min-h-screen bg-gradient-to-b from-black via-gray-900 to-black py-20 px-8">
  <div class="max-w-7xl mx-auto">
    <div class="text-center mb-16 scroll-animate" data-animation="fadeIn">
      <h2 class="text-5xl md:text-7xl font-bold text-white mb-6 tracking-wider">
        CONTACTO
      </h2>
      <p class="text-xl text-gray-300 max-w-3xl mx-auto leading-relaxed">
        ¿Tienes una idea para tu próximo tatuaje? Contáctanos y hagamos realidad tu visión.
      </p>
    </div>

    <div class="grid lg:grid-cols-2 gap-16">
      <!-- Información de Contacto -->
      <div class="scroll-animate" data-animation="slideInLeft" data-delay="0.2">
        <h3 class="text-3xl font-bold text-white mb-8">Información de Contacto</h3>
        
        <div class="space-y-6">
          <!-- Dirección -->
          <div class="flex items-start space-x-4">
            <div class="w-12 h-12 bg-amber-400 rounded-full flex items-center justify-center flex-shrink-0">
              <svg class="w-6 h-6 text-black" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
              </svg>
            </div>
            <div>
              <h4 class="text-xl font-semibold text-white mb-2">Dirección</h4>
              <p class="text-gray-300">
                Calle 23 #456, Vedado<br>
                La Habana, Cuba 10400
              </p>
            </div>
          </div>

          <!-- Teléfono -->
          <div class="flex items-start space-x-4">
            <div class="w-12 h-12 bg-amber-400 rounded-full flex items-center justify-center flex-shrink-0">
              <svg class="w-6 h-6 text-black" fill="currentColor" viewBox="0 0 24 24">
                <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
              </svg>
            </div>
            <div>
              <h4 class="text-xl font-semibold text-white mb-2">Teléfono</h4>
              <p class="text-gray-300">
                +53 7 832-1234<br>
                +53 5 234-5678 (WhatsApp)
              </p>
            </div>
          </div>

          <!-- Email -->
          <div class="flex items-start space-x-4">
            <div class="w-12 h-12 bg-amber-400 rounded-full flex items-center justify-center flex-shrink-0">
              <svg class="w-6 h-6 text-black" fill="currentColor" viewBox="0 0 24 24">
                <path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.89 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/>
              </svg>
            </div>
            <div>
              <h4 class="text-xl font-semibold text-white mb-2">Email</h4>
              <p class="text-gray-300">
                info@cubatattoostudio.com<br>
                citas@cubatattoostudio.com
              </p>
            </div>
          </div>

          <!-- Horarios -->
          <div class="flex items-start space-x-4">
            <div class="w-12 h-12 bg-amber-400 rounded-full flex items-center justify-center flex-shrink-0">
              <svg class="w-6 h-6 text-black" fill="currentColor" viewBox="0 0 24 24">
                <path d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8z"/>
                <path d="M12.5 7H11v6l5.25 3.15.75-1.23-4.5-2.67z"/>
              </svg>
            </div>
            <div>
              <h4 class="text-xl font-semibold text-white mb-2">Horarios</h4>
              <p class="text-gray-300">
                Lunes - Viernes: 10:00 AM - 8:00 PM<br>
                Sábados: 10:00 AM - 6:00 PM<br>
                Domingos: Cerrado
              </p>
            </div>
          </div>
        </div>

        <!-- Redes Sociales -->
        <div class="mt-12">
          <h4 class="text-xl font-semibold text-white mb-6">Síguenos en Redes Sociales</h4>
          <div class="flex space-x-4">
            <button class="w-12 h-12 bg-amber-400 rounded-full flex items-center justify-center hover:bg-amber-300 transition-colors duration-300">
              <svg class="w-6 h-6 text-black" fill="currentColor" viewBox="0 0 24 24">
                <path d="M24 4.557c-.883.392-1.832.656-2.828.775 1.017-.609 1.798-1.574 2.165-2.724-.951.564-2.005.974-3.127 1.195-.897-.957-2.178-1.555-3.594-1.555-3.179 0-5.515 2.966-4.797 6.045-4.091-.205-7.719-2.165-10.148-5.144-1.29 2.213-.669 5.108 1.523 6.574-.806-.026-1.566-.247-2.229-.616-.054 2.281 1.581 4.415 3.949 4.89-.693.188-1.452.232-2.224.084.626 1.956 2.444 3.379 4.6 3.419-2.07 1.623-4.678 2.348-7.29 2.04 2.179 1.397 4.768 2.212 7.548 2.212 9.142 0 14.307-7.721 13.995-14.646.962-.695 1.797-1.562 2.457-2.549z"/>
              </svg>
            </button>
            <button class="w-12 h-12 bg-amber-400 rounded-full flex items-center justify-center hover:bg-amber-300 transition-colors duration-300">
              <svg class="w-6 h-6 text-black" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12.017 0C5.396 0 .029 5.367.029 11.987c0 5.079 3.158 9.417 7.618 11.174-.105-.949-.199-2.405.042-3.441.219-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738.098.119.112.224.083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.357-.631-2.746-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24.009 12.017 24.009c6.624 0 11.99-5.367 11.99-11.988C24.007 5.367 18.641.001.012.001z"/>
              </svg>
            </button>
            <button class="w-12 h-12 bg-amber-400 rounded-full flex items-center justify-center hover:bg-amber-300 transition-colors duration-300">
              <svg class="w-6 h-6 text-black" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
              </svg>
            </button>
            <button class="w-12 h-12 bg-amber-400 rounded-full flex items-center justify-center hover:bg-amber-300 transition-colors duration-300">
              <svg class="w-6 h-6 text-black" fill="currentColor" viewBox="0 0 24 24">
                <path d="M9 8h-3v4h3v12h5v-12h3.642l.358-4h-4v-1.667c0-.955.192-1.333 1.115-1.333h2.885v-5h-3.808c-3.596 0-5.192 1.583-5.192 4.615v3.385z"/>
              </svg>
            </button>
          </div>
        </div>
      </div>

      <!-- Formulario de Contacto -->
      <div class="scroll-animate" data-animation="slideInRight" data-delay="0.4">
        <h3 class="text-3xl font-bold text-white mb-8">Envíanos un Mensaje</h3>
        
        <form class="space-y-6" id="contact-form">
          <div class="grid md:grid-cols-2 gap-6">
            <div>
              <label class="block text-white font-medium mb-2" for="name">Nombre</label>
              <input 
                type="text" 
                id="name" 
                name="name" 
                class="w-full px-4 py-3 bg-gray-800 border border-gray-700 rounded-lg text-white focus:border-amber-400 focus:outline-none transition-colors duration-300"
                placeholder="Tu nombre"
                required
              />
            </div>
            <div>
              <label class="block text-white font-medium mb-2" for="email">Email</label>
              <input 
                type="email" 
                id="email" 
                name="email" 
                class="w-full px-4 py-3 bg-gray-800 border border-gray-700 rounded-lg text-white focus:border-amber-400 focus:outline-none transition-colors duration-300"
                placeholder="tu@email.com"
                required
              />
            </div>
          </div>

          <div>
            <label class="block text-white font-medium mb-2" for="phone">Teléfono</label>
            <input 
              type="tel" 
              id="phone" 
              name="phone" 
              class="w-full px-4 py-3 bg-gray-800 border border-gray-700 rounded-lg text-white focus:border-amber-400 focus:outline-none transition-colors duration-300"
              placeholder="+53 5 234-5678"
            />
          </div>

          <div>
            <label class="block text-white font-medium mb-2" for="service">Tipo de Servicio</label>
            <select 
              id="service" 
              name="service" 
              class="w-full px-4 py-3 bg-gray-800 border border-gray-700 rounded-lg text-white focus:border-amber-400 focus:outline-none transition-colors duration-300"
              required
            >
              <option value="">Selecciona un servicio</option>
              <option value="consulta">Consulta de Diseño</option>
              <option value="tradicional">Tatuaje Tradicional</option>
              <option value="realista">Tatuaje Realista</option>
              <option value="geometrico">Tatuaje Geométrico</option>
              <option value="color">Tatuaje en Color</option>
              <option value="coverup">Cover-up</option>
              <option value="otro">Otro</option>
            </select>
          </div>

          <div>
            <label class="block text-white font-medium mb-2" for="message">Mensaje</label>
            <textarea 
              id="message" 
              name="message" 
              rows="6"
              class="w-full px-4 py-3 bg-gray-800 border border-gray-700 rounded-lg text-white focus:border-amber-400 focus:outline-none transition-colors duration-300 resize-none"
              placeholder="Cuéntanos sobre tu idea de tatuaje, tamaño, ubicación, y cualquier detalle que consideres importante..."
              required
            ></textarea>
          </div>

          <button 
            type="submit"
            class="w-full bg-amber-400 text-black px-8 py-4 rounded-lg font-bold text-lg hover:bg-amber-300 transition-colors duration-300 hover:scale-105 transform"
          >
            Enviar Mensaje
          </button>
        </form>
      </div>
    </div>
  </div>
</section>

<script>
  // Solo funcionalidad de formulario y validación
  function initContactForm() {
    const form = document.querySelector("#contact-form") as HTMLFormElement
    if (!form) return

    const inputs = form.querySelectorAll("input, textarea, select")
    
    inputs.forEach(input => {
      const htmlInput = input as HTMLInputElement
      
      // Mejorar experiencia de usuario con focus/blur
      htmlInput.addEventListener('focus', () => {
        htmlInput.style.borderColor = "#fbbf24"
        htmlInput.style.boxShadow = "0 0 0 2px rgba(251, 191, 36, 0.2)"
      })

      htmlInput.addEventListener('blur', () => {
        if (!htmlInput.value) {
          htmlInput.style.borderColor = "#374151"
          htmlInput.style.boxShadow = "none"
        }
      })
    })

    // Manejo del envío del formulario
    form.addEventListener('submit', (e) => {
      e.preventDefault()
      
      // Aquí puedes agregar la lógica de envío real
      console.log("Formulario enviado")
      
      // Feedback visual simple
      const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement
      if (submitBtn) {
        const originalText = submitBtn.textContent
        submitBtn.textContent = "Enviando..."
        submitBtn.disabled = true
        
        setTimeout(() => {
          submitBtn.textContent = "¡Mensaje Enviado!"
          setTimeout(() => {
            submitBtn.textContent = originalText
            submitBtn.disabled = false
            form.reset()
          }, 2000)
        }, 1000)
      }
    })

    console.log("Contact form initialized")
  }

  // Inicializar
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initContactForm)
  } else {
    initContactForm()
  }

  document.addEventListener('astro:page-load', initContactForm)
</script>
