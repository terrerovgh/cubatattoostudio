---
import SectionWrapper from "../SectionWrapper.astro";
import { Button } from "@cloudflare/kumo";

interface Props {
  id: string;
  backgroundImage: string;
  title?: string;
  subtitle?: string;
}

const { id, backgroundImage, title, subtitle } = Astro.props;
---

<SectionWrapper id={id} backgroundImage={backgroundImage} class="!py-0">
  {/* Modern Abstract Ambient Background */}
  <div
    class="absolute inset-0 overflow-hidden pointer-events-none select-none bg-gradient-to-b from-[#08080a] via-[#111115] to-[#0a0a0d]"
  >
    {/* Subtle Animated Grain Overlay */}
    <div
      class="absolute inset-0 opacity-[0.03] mix-blend-overlay"
      style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 200 200%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22noiseFilter%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.65%22 numOctaves=%223%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23noiseFilter)%22/%3E%3C/svg%3E');"
    >
    </div>

    {/* Primary Ambient Glow */}
    <div
      class="absolute top-[20%] left-1/2 -translate-x-1/2 w-[80vw] max-w-[800px] aspect-square rounded-full mix-blend-screen animate-pulse pointer-events-none"
      style="background: radial-gradient(circle, rgba(200,149,108,0.08) 0%, rgba(200,149,108,0) 65%); animation-duration: 8s;"
    >
    </div>

    {/* Secondary Accent Glow */}
    <div
      class="absolute bottom-[10%] left-[30%] -translate-x-1/2 w-[60vw] max-w-[600px] aspect-square rounded-full mix-blend-screen animate-pulse pointer-events-none delay-1000"
      style="background: radial-gradient(circle, rgba(218,186,143,0.04) 0%, rgba(218,186,143,0) 60%); animation-duration: 12s;"
    >
    </div>

    {/* Floating Golden Embers (CSS Animation via global classes) */}
    <div class="absolute inset-0" aria-hidden="true">
      <div
        class="hero-particle w-1.5 h-1.5 top-[30%] left-[15%] opacity-40 blur-[1px]"
        style="--duration: 14s; --delay: 0s;"
      >
      </div>
      <div
        class="hero-particle w-1 h-1 top-[60%] left-[80%] opacity-30 blur-[0.5px]"
        style="--duration: 18s; --delay: 2s;"
      >
      </div>
      <div
        class="hero-particle w-2 h-2 top-[20%] left-[70%] opacity-20 blur-[2px]"
        style="--duration: 22s; --delay: 5s;"
      >
      </div>
      <div
        class="hero-particle w-1.5 h-1.5 top-[80%] left-[25%] opacity-50 blur-[1px]"
        style="--duration: 16s; --delay: 8s;"
      >
      </div>
      <div
        class="hero-particle w-1 h-1 top-[40%] left-[50%] opacity-25 blur-[0.5px]"
        style="--duration: 20s; --delay: 11s;"
      >
      </div>
      <div
        class="hero-particle w-2 h-2 top-[70%] left-[60%] opacity-15 blur-[2.5px]"
        style="--duration: 25s; --delay: 14s;"
      >
      </div>
    </div>
  </div>

  {/* Deep Vignette */}
  <div
    class="absolute inset-0 pointer-events-none"
    style="box-shadow: inset 0 0 120px rgba(8,8,10,0.95), inset 0 0 40px rgba(8,8,10,0.8);"
  >
  </div>

  {/* Main content — vertically centered */}
  <div
    class="relative z-10 flex flex-col items-center justify-center text-center px-6 sm:px-8 max-w-4xl mx-auto min-h-[100dvh] py-24 stagger-children"
  >
    {/* Animated Centerpiece Logo */}
    <div
      data-hero="logo"
      class="w-full mb-8 sm:mb-12 relative flex flex-col items-center justify-center"
    >
      {/* Dynamic Aura Glow */}
      <div
        class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[180%] h-[180%] bg-[var(--color-gold)] opacity-[0.06] blur-[100px] rounded-full pointer-events-none mix-blend-screen pulse-aura"
      >
      </div>

      <div
        class="relative w-full max-w-[280px] sm:max-w-[420px] lg:max-w-[500px] flex items-center justify-center"
        data-magnetic
      >
        <div class="elegant-float">
          <img
            src="/logo.svg"
            alt="Cuba Tattoo Studio"
            class="w-full h-auto drop-shadow-[0_15px_35px_rgba(0,0,0,0.8)] prismic-shine relative z-10"
          />
        </div>
      </div>
    </div>

    {/* Elegant divider */}
    <div
      data-hero="line"
      class="w-16 sm:w-24 h-[1px] mx-auto mb-8 sm:mb-12 rounded-full"
      style="background: linear-gradient(90deg, transparent, rgba(200, 149, 108, 0.8), transparent);"
    >
    </div>

    {/* Subtitle */}
    {
      subtitle && (
        <p
          data-hero="subtitle"
          class="text-fluid-body-lg text-white/60 font-light max-w-[280px] sm:max-w-xl lg:max-w-2xl mx-auto tracking-wide leading-relaxed mb-12 sm:mb-16"
        >
          {subtitle}
        </p>
      )
    }

    {/* CTA Buttons Row */}
    <div
      data-hero="cta"
      class="flex flex-col sm:flex-row items-center justify-center gap-4 sm:gap-6 w-full sm:w-auto"
    >
      {/* Primary Booking Button */}
      <Button
        client:load
        as="a"
        href="#booking"
        className="group relative inline-flex items-center justify-center gap-3
               px-8 py-4 sm:px-10 sm:py-[1.125rem] w-full sm:w-auto min-w-[240px] rounded-2xl
               bg-gradient-to-b from-[#DABA8F] to-[#C8956C] text-[#08080a] font-bold text-sm sm:text-base tracking-widest uppercase
               shadow-[0_4px_20px_rgba(200,149,108,0.2)]
               transition-all duration-500 ease-in-out overflow-hidden
               hover:shadow-[0_8px_30px_rgba(200,149,108,0.4)] hover:-translate-y-1 active:scale-[0.98] active:translate-y-0"
        data-magnetic
      >
        <div
          class="absolute inset-0 bg-white/20 translate-y-[-100%] group-hover:translate-y-[100%] transition-transform duration-700 ease-in-out"
        >
        </div>
        <span class="relative z-10">Start Consultation</span>
        <svg
          class="relative z-10 w-4 h-4 sm:w-5 sm:h-5 transition-transform duration-300 group-hover:translate-x-1"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2.5"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"></path>
        </svg>
      </Button>

      {/* Secondary Gallery Action */}
      <Button
        client:load
        as="a"
        href="#gallery"
        variant="ghost"
        className="group relative inline-flex items-center justify-center
               px-8 py-4 sm:px-10 sm:py-[1.125rem] w-full sm:w-auto min-w-[240px] rounded-2xl
               bg-transparent text-white/90 font-bold text-sm sm:text-base tracking-widest uppercase
               border border-white/10 backdrop-blur-md
               transition-all duration-300 ease-out
               hover:bg-white/5 hover:border-white/20 hover:text-white"
        data-magnetic
      >
        <span class="relative z-10">Explore Work</span>
      </Button>
    </div>
  </div>

  {/* Minimalist Scroll indicator */}
  <div
    data-hero="scroll"
    class="scroll-indicator absolute bottom-8 sm:bottom-10 pb-[env(safe-area-inset-bottom,0px)] left-1/2 -translate-x-1/2 z-[5] flex flex-col items-center gap-2 cursor-pointer"
    onclick="document.getElementById('artists').scrollIntoView({behavior: 'smooth'})"
  >
    <div
      class="w-[1px] h-12 bg-gradient-to-b from-white/0 via-white/20 to-white/0 mb-1"
    >
    </div>
    <span
      class="text-[9px] sm:text-[10px] uppercase tracking-[0.25em] text-white/30 font-medium hover:text-white/50 transition-colors"
      >Discover</span
    >
  </div>
</SectionWrapper>

<style>
  .pulse-aura {
    animation: pulseAura 8s ease-in-out infinite;
  }
  @keyframes pulseAura {
    0%,
    100% {
      opacity: 0.04;
      transform: translate(-50%, -50%) scale(1);
      filter: blur(80px);
    }
    50% {
      opacity: 0.1;
      transform: translate(-50%, -50%) scale(1.05);
      filter: blur(100px);
    }
  }

  .elegant-float {
    animation: elegantFloat 6s ease-in-out infinite;
    transform-origin: center;
  }
  @keyframes elegantFloat {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-8px);
    }
  }

  .prismic-shine {
    animation: prismicShine 6s ease-in-out infinite;
    will-change: filter;
  }
  @keyframes prismicShine {
    0%,
    100% {
      filter: drop-shadow(0 15px 35px rgba(0, 0, 0, 0.8)) brightness(1);
    }
    50% {
      filter: drop-shadow(0 20px 45px rgba(200, 149, 108, 0.35))
        brightness(1.25);
    }
  }
</style>
