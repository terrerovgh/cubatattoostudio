---
import SectionWrapper from "../SectionWrapper.astro";
import { Button } from "@cloudflare/kumo";

interface Props {
  id: string;
  backgroundImage: string;
  title?: string;
  subtitle?: string;
  bookingUrl?: string;
  phone?: string;
  email?: string;
  address?: string;
}

const {
  id,
  backgroundImage,
  title,
  subtitle,
  bookingUrl,
  phone,
  email,
  address,
} = Astro.props;
---

<SectionWrapper id={id} backgroundImage={backgroundImage}>
  <div class="container-standard">
    <div
      class="grid grid-cols-1 lg:grid-cols-3 gap-6 sm:gap-8 stagger-children"
    >
      {/* 1. Massive Main Booking CTA */}
      <div
        class="lg:col-span-2 relative overflow-hidden group rounded-[2rem] sm:rounded-[3rem] bg-[#0a0a0d] border border-white/5 p-8 sm:p-12 lg:p-16 flex flex-col justify-center min-h-[400px] hover:border-[var(--color-gold)]/30 transition-all duration-700 hover:shadow-[0_0_80px_rgba(200,149,108,0.15)]"
        data-animate-left
      >
        {/* Radiant Gold Glow Background */}
        <div
          class="absolute inset-0 bg-gradient-to-br from-[var(--color-gold)]/10 via-transparent to-transparent opacity-50 group-hover:opacity-100 transition-opacity duration-700"
        >
        </div>
        <div
          class="absolute -top-40 -left-40 w-96 h-96 bg-[var(--color-gold)] mix-blend-screen opacity-10 blur-[100px] rounded-full group-hover:opacity-20 transition-opacity duration-1000"
        >
        </div>

        <div class="relative z-10 space-y-6 sm:space-y-8 max-w-lg">
          <div class="space-y-4">
            <h2
              class="text-3xl sm:text-4xl lg:text-5xl font-light tracking-tight text-white leading-[1.1]"
            >
              <span
                class="block text-transparent bg-clip-text bg-gradient-to-b from-[#FFFFFF] to-[#A0A0A0]"
                >{title || "Your Next Masterpiece."}</span
              >
              <span class="font-medium text-[var(--color-gold)]"
                >Starts Here.</span
              >
            </h2>
            <p
              class="text-white/50 text-base sm:text-lg font-light leading-relaxed"
            >
              {
                subtitle ||
                  "Secure your consultation and let’s turn your vision into permanent art."
              }
            </p>
          </div>

          <div class="pt-2">
            <Button
              client:load
              as="a"
              href={bookingUrl || "/booking"}
              className="group/btn relative inline-flex items-center gap-4 px-8 py-4 sm:px-10 sm:py-5 rounded-2xl
                     bg-gradient-to-b from-[#DABA8F] to-[#C8956C] text-[#08080a] font-bold text-sm sm:text-base tracking-wide
                     overflow-hidden transition-all duration-500 hover:scale-[1.02] hover:shadow-[0_12px_40px_rgba(200,149,108,0.3)] active:scale-[0.98]"
            >
              <div
                class="absolute inset-0 bg-white/20 translate-y-[100%] group-hover/btn:translate-y-0 transition-transform duration-500 ease-out"
              >
              </div>
              <span
                class="relative z-10 uppercase tracking-widest text-xs sm:text-sm"
                >Initiate Booking</span
              >
              <svg
                class="relative z-10 w-5 h-5 transition-transform duration-500 group-hover/btn:translate-x-1.5"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
              </svg>
            </Button>
          </div>
        </div>

        {/* Premium Graphic Element */}
        <div
          class="absolute right-0 bottom-0 opacity-10 group-hover:opacity-20 transition-opacity duration-700 pointer-events-none translate-x-1/4 translate-y-1/4"
        >
          <img
            src="/logo.svg"
            alt=""
            class="w-[300px] h-[300px] lg:w-[450px] lg:h-[450px]"
          />
        </div>
      </div>

      {/* 2. Contact & Quick Links Stack */}
      <div class="flex flex-col gap-6 sm:gap-8 h-full" data-animate-right>
        {/* Contact Info Card */}
        <div
          class="flex-1 rounded-[2rem] bg-white/[0.02] border border-white/[0.05] p-6 flex flex-col justify-center space-y-6 hover:bg-white/[0.04] hover:border-white/10 transition-all duration-500 liquid-glass-elevated"
        >
          <div class="flex items-center gap-3">
            <div
              class="w-10 h-10 rounded-full border border-white/10 flex items-center justify-center bg-white/5"
            >
              <svg
                class="w-4 h-4 text-[var(--color-gold)]"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                ></path>
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
              </svg>
            </div>
            <h3 class="text-lg font-medium tracking-wide text-white">
              Contact Info
            </h3>
          </div>

          <div class="space-y-4">
            {
              phone && (
                <a
                  href={`tel:${phone.replace(/[^+\d]/g, "")}`}
                  class="flex items-center gap-4 text-white/60 hover:text-[var(--color-gold)] transition-colors group"
                >
                  <span class="text-xs font-semibold tracking-widest uppercase opacity-50 w-16">
                    Phone
                  </span>
                  <span class="text-sm font-light group-hover:translate-x-1 transition-transform">
                    {phone}
                  </span>
                </a>
              )
            }
            {
              email && (
                <a
                  href={`mailto:${email}`}
                  class="flex items-center gap-4 text-white/60 hover:text-[var(--color-gold)] transition-colors group"
                >
                  <span class="text-xs font-semibold tracking-widest uppercase opacity-50 w-16">
                    Email
                  </span>
                  <span class="text-sm font-light truncate group-hover:translate-x-1 transition-transform">
                    {email}
                  </span>
                </a>
              )
            }
            {
              address && (
                <div class="flex items-start gap-4 text-white/60">
                  <span class="text-xs font-semibold tracking-widest uppercase opacity-50 w-16 pt-0.5">
                    Studio
                  </span>
                  <span class="text-sm font-light leading-relaxed flex-1">
                    {address}
                  </span>
                </div>
              )
            }
          </div>
        </div>

        {/* Studio Connect / Socials Card */}
        <div
          class="rounded-[2rem] bg-white/[0.02] border border-white/[0.05] p-6 flex items-center justify-between hover:bg-white/[0.04] hover:border-white/10 transition-all duration-500 liquid-glass-elevated"
        >
          <div class="w-full space-y-4">
            <h3
              class="text-xs font-semibold tracking-widest uppercase text-white/50 mb-4"
            >
              Connect
            </h3>
            <div class="flex gap-3">
              <a
                href="https://instagram.com/cubatattoostudio"
                target="_blank"
                rel="noopener noreferrer"
                class="flex-1 flex items-center justify-center gap-2 py-3 rounded-xl bg-white/5 hover:bg-[var(--color-gold)] hover:text-[#08080a] text-white/70 transition-all duration-300"
              >
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"
                  ><path
                    d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"
                  ></path></svg
                >
                <span class="text-xs font-semibold">Insta</span>
              </a>
              <a
                href="https://facebook.com/cubatattoostudio"
                target="_blank"
                rel="noopener noreferrer"
                class="flex-1 flex items-center justify-center gap-2 py-3 rounded-xl bg-white/5 hover:bg-[#1877F2] hover:text-white text-white/70 transition-all duration-300"
              >
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"
                  ><path
                    d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"
                  ></path></svg
                >
                <span class="text-xs font-semibold">Face</span>
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</SectionWrapper>
