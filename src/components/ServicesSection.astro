---
---

<section id="services" class="min-h-screen bg-gradient-to-b from-black via-gray-900 to-black py-20 px-8">
  <div class="max-w-7xl mx-auto">
    <div class="text-center mb-16">
      <h2 class="text-5xl md:text-7xl font-bold text-white mb-6 tracking-wider scroll-animate" data-animation="fadeIn">
        NUESTROS SERVICIOS
      </h2>
      <p class="text-xl text-gray-300 max-w-3xl mx-auto leading-relaxed scroll-animate" data-animation="fadeIn" data-delay="0.2">
        Ofrecemos una amplia gama de servicios de tatuaje profesional con los más altos estándares de calidad y seguridad.
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      <!-- Tatuajes Tradicionales -->
      <div class="group bg-gradient-to-br from-gray-800 to-gray-900 p-8 rounded-2xl hover:from-amber-900 hover:to-gray-800 transition-all duration-500 hover:scale-105 border border-gray-700 scroll-animate" data-animation="fadeIn" data-delay="0.3">
        <div class="w-16 h-16 bg-amber-400 rounded-full flex items-center justify-center mb-6 group-hover:bg-white transition-colors duration-500">
          <svg class="w-8 h-8 text-black" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
          </svg>
        </div>
        <h3 class="text-2xl font-bold text-white mb-4">Tatuajes Tradicionales</h3>
        <p class="text-gray-300 leading-relaxed">
          Diseños clásicos y atemporales con técnicas tradicionales perfeccionadas a lo largo de los años.
        </p>
      </div>

      <!-- Tatuajes Realistas -->
      <div class="group bg-gradient-to-br from-gray-800 to-gray-900 p-8 rounded-2xl hover:from-amber-900 hover:to-gray-800 transition-all duration-500 hover:scale-105 border border-gray-700 scroll-animate" data-animation="fadeIn" data-delay="0.4">
        <div class="w-16 h-16 bg-amber-400 rounded-full flex items-center justify-center mb-6 group-hover:bg-white transition-colors duration-500">
          <svg class="w-8 h-8 text-black" fill="currentColor" viewBox="0 0 24 24">
            <path d="M9 11H7v2h2v-2zm4 0h-2v2h2v-2zm4 0h-2v2h2v-2zm2-7h-1V2h-2v2H8V2H6v2H5c-1.1 0-1.99.9-1.99 2L3 20c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 16H5V9h14v11z"/>
          </svg>
        </div>
        <h3 class="text-2xl font-bold text-white mb-4">Tatuajes Realistas</h3>
        <p class="text-gray-300 leading-relaxed">
          Retratos y diseños hiperrealistas que capturan cada detalle con precisión fotográfica.
        </p>
      </div>

      <!-- Tatuajes Geométricos -->
      <div class="group bg-gradient-to-br from-gray-800 to-gray-900 p-8 rounded-2xl hover:from-amber-900 hover:to-gray-800 transition-all duration-500 hover:scale-105 border border-gray-700 scroll-animate" data-animation="fadeIn" data-delay="0.5">
        <div class="w-16 h-16 bg-amber-400 rounded-full flex items-center justify-center mb-6 group-hover:bg-white transition-colors duration-500">
          <svg class="w-8 h-8 text-black" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 7.77L18.39 18H5.61L12 7.77M12 4L2 20h20L12 4z"/>
          </svg>
        </div>
        <h3 class="text-2xl font-bold text-white mb-4">Tatuajes Geométricos</h3>
        <p class="text-gray-300 leading-relaxed">
          Patrones y formas geométricas perfectas que combinan arte moderno con precisión matemática.
        </p>
      </div>

      <!-- Cover-ups -->
      <div class="group bg-gradient-to-br from-gray-800 to-gray-900 p-8 rounded-2xl hover:from-amber-900 hover:to-gray-800 transition-all duration-500 hover:scale-105 border border-gray-700 scroll-animate" data-animation="fadeIn" data-delay="0.6">
        <div class="w-16 h-16 bg-amber-400 rounded-full flex items-center justify-center mb-6 group-hover:bg-white transition-colors duration-500">
          <svg class="w-8 h-8 text-black" fill="currentColor" viewBox="0 0 24 24">
            <path d="M14.06 9.02l.92.92L5.92 19H5v-.92l9.06-9.06M17.66 3c-.25 0-.51.1-.7.29l-1.83 1.83 3.75 3.75 1.83-1.83c.39-.39.39-1.02 0-1.41l-2.34-2.34c-.2-.2-.45-.29-.71-.29zm-3.6 3.19L3 17.25V21h3.75L17.81 9.94l-3.75-3.75z"/>
          </svg>
        </div>
        <h3 class="text-2xl font-bold text-white mb-4">Cover-ups</h3>
        <p class="text-gray-300 leading-relaxed">
          Transformamos tatuajes antiguos en obras de arte nuevas con técnicas especializadas de cover-up.
        </p>
      </div>

      <!-- Tatuajes en Color -->
      <div class="group bg-gradient-to-br from-gray-800 to-gray-900 p-8 rounded-2xl hover:from-amber-900 hover:to-gray-800 transition-all duration-500 hover:scale-105 border border-gray-700 scroll-animate" data-animation="fadeIn" data-delay="0.7">
        <div class="w-16 h-16 bg-amber-400 rounded-full flex items-center justify-center mb-6 group-hover:bg-white transition-colors duration-500">
          <svg class="w-8 h-8 text-black" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 3c-4.97 0-9 4.03-9 9s4.03 9 9 9c.83 0 1.5-.67 1.5-1.5 0-.39-.15-.74-.39-1.01-.23-.26-.38-.61-.38-.99 0-.83.67-1.5 1.5-1.5H16c2.76 0 5-2.24 5-5 0-4.42-4.03-8-9-8z"/>
          </svg>
        </div>
        <h3 class="text-2xl font-bold text-white mb-4">Tatuajes en Color</h3>
        <p class="text-gray-300 leading-relaxed">
          Diseños vibrantes y coloridos que dan vida a tu piel con pigmentos de la más alta calidad.
        </p>
      </div>

      <!-- Consultoría de Diseño -->
      <div class="group bg-gradient-to-br from-gray-800 to-gray-900 p-8 rounded-2xl hover:from-amber-900 hover:to-gray-800 transition-all duration-500 hover:scale-105 border border-gray-700 scroll-animate" data-animation="fadeIn" data-delay="0.8">
        <div class="w-16 h-16 bg-amber-400 rounded-full flex items-center justify-center mb-6 group-hover:bg-white transition-colors duration-500">
          <svg class="w-8 h-8 text-black" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
          </svg>
        </div>
        <h3 class="text-2xl font-bold text-white mb-4">Consultoría de Diseño</h3>
        <p class="text-gray-300 leading-relaxed">
          Trabajamos contigo para crear el diseño perfecto que capture tu visión y personalidad única.
        </p>
      </div>
    </div>

    <div class="text-center mt-16 scroll-animate" data-animation="fadeIn" data-delay="0.9">
      <button class="bg-amber-400 text-black px-8 py-4 rounded-full font-bold text-lg hover:bg-amber-300 transition-colors duration-300 hover:scale-105 transform">
        Agenda tu Consulta
      </button>
    </div>
  </div>
</section>


