---
import DynamicBackground from './DynamicBackground.astro';
import FloatingVisuals from './FloatingVisuals.astro';
---
<section id="hero-section" class="relative h-screen w-full flex items-center justify-center text-center text-white overflow-hidden">
  <DynamicBackground images={["/gallery/color/tattoo-color-1.jpg","/gallery/geometric/tattoo-geometric-1.jpg","/gallery/realistic/tattoo-realistic-1.jpg"]} />
  <FloatingVisuals />
  <div class="relative z-10">
    <img id="hero-logo" src="/logo-black.png" alt="Cuba Tattoo Studio Logo" class="w-48 mx-auto mb-4" />
    <h1 id="hero-text" class="text-4xl md:text-6xl font-bold mb-4">Donde el arte se encuentra con la piel</h1>
    <a href="#contacto" class="bg-amber-400 text-black px-6 py-3 rounded-lg hover:bg-amber-500 transition">Reserva tu cita</a>
  </div>
</section>

<script is:client="load">
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);
  gsap.from('#hero-logo',{opacity:0,scale:0.8,duration:1});
  gsap.from('#hero-text',{opacity:0,y:40,duration:1,delay:0.5});
</script>
