---

<div id="loading-screen" class="fixed inset-0 z-50 bg-black flex items-center justify-center">
  <!-- Spinner minimalista -->
  <div class="relative">
    <!-- Spinner principal -->
    <div class="w-12 h-12 border-2 border-gray-800 border-t-amber-400 rounded-full animate-spin"></div>
    <!-- Círculo interior para más estilo -->
    <div class="absolute inset-2 w-8 h-8 border border-gray-700 border-b-amber-500 rounded-full animate-spin" style="animation-duration: 0.8s; animation-direction: reverse;"></div>
  </div>
</div>

<!-- Script externo para evitar conflictos -->
<script src="/loading-screen.js" is:inline></script>

<style>
  /* Animación suave de fade out */
  #loading-screen.fade-out {
    opacity: 0;
    transition: opacity 0.8s ease-out;
  }
</style>
