---
const { images = [] } = Astro.props;
---
<div class="absolute inset-0 overflow-hidden" id="dynamic-bg">
  {images.map((src, i) => (
    <img src={src} alt="" class="absolute inset-0 w-full h-full object-cover opacity-0" style={`animation-delay:${i*5}s`} />
  ))}
</div>

<style>
  #dynamic-bg img { animation: fade 15s infinite; }
  @keyframes fade {
    0%,20%{opacity:0}
    5%,15%{opacity:1}
  }
</style>
