---
import Heading from './Heading.astro';
import Button from './Button.astro';
import ImageOptimized from './ImageOptimized.astro';

export interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;
---

<section class={`py-20 bg-white ${className}`}>
  <div class="container mx-auto px-4">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <!-- Artist Image -->
      <div class="relative">
        <div class="aspect-[4/5] bg-gray-200 rounded-lg overflow-hidden">
          <!-- Placeholder for artist image -->
          <div class="w-full h-full bg-gradient-to-br from-gray-300 to-gray-400 flex items-center justify-center">
            <span class="text-gray-600 text-lg">Foto de David</span>
          </div>
        </div>
        
        <!-- Decorative element -->
        <div class="absolute -bottom-4 -right-4 w-24 h-24 bg-red-600 rounded-lg opacity-20"></div>
      </div>

      <!-- Artist Info -->
      <div>
        <Heading level={2} class="mb-6">
          David
          <span class="block text-lg font-normal text-gray-600 mt-2">
            Especialista en Realismo y Retratos
          </span>
        </Heading>

        <div class="prose prose-lg mb-8">
          <p class="text-gray-700 mb-4">
            Con más de 8 años de experiencia, David se ha especializado en el arte del realismo 
            y los retratos hiperrealistas. Su atención al detalle y técnica impecable lo han 
            convertido en uno de los artistas más solicitados del estudio.
          </p>
          
          <p class="text-gray-700 mb-6">
            Graduado de la Academia de Bellas Artes de La Habana, David combina técnicas 
            tradicionales con innovación moderna para crear obras únicas que perduran en el tiempo.
          </p>
        </div>

        <!-- Specialties -->
        <div class="mb-8">
          <h3 class="text-xl font-semibold mb-4">Especialidades:</h3>
          <div class="flex flex-wrap gap-2">
            <span class="px-3 py-1 bg-gray-100 text-gray-800 rounded-full text-sm">Realismo</span>
            <span class="px-3 py-1 bg-gray-100 text-gray-800 rounded-full text-sm">Retratos</span>
            <span class="px-3 py-1 bg-gray-100 text-gray-800 rounded-full text-sm">Blanco y Negro</span>
            <span class="px-3 py-1 bg-gray-100 text-gray-800 rounded-full text-sm">Sombreado</span>
          </div>
        </div>

        <!-- Portfolio Preview -->
        <div class="mb-8">
          <h3 class="text-xl font-semibold mb-4">Trabajos Destacados:</h3>
          <div class="grid grid-cols-3 gap-2">
            <div class="aspect-square bg-gray-200 rounded-lg"></div>
            <div class="aspect-square bg-gray-200 rounded-lg"></div>
            <div class="aspect-square bg-gray-200 rounded-lg"></div>
          </div>
        </div>

        <!-- CTA Button -->
        <Button 
          href="/booking?artist=david" 
          variant="primary" 
          size="lg"
          class="bg-red-600 hover:bg-red-700 border-none"
        >
          Reservar con David
        </Button>
      </div>
    </div>
  </div>
</section>
