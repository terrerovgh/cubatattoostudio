---
import { artistas } from '../../data/artistas.js'; // Corregida la ruta a data
import ArtistaCard from './ArtistaCard.astro';
import Heading from '../Heading.astro'; // Ruta un nivel arriba
import Button from '../Button.astro';   // Ruta un nivel arriba
---

<section id="artists" class="min-h-screen py-20 px-8 relative z-20 bg-gray-900"> {/* Añadido un fondo para mejor contraste si es necesario */}
  <div class="max-w-7xl mx-auto">
    <div class="text-center mb-16 scroll-animate" data-animation="fadeIn">
      <Heading level={2} size="4xl" variant="primary" class="mb-6 tracking-wider text-white">
        NUESTROS ARTISTAS
      </Heading>
      <p class="text-xl text-gray-300 max-w-3xl mx-auto leading-relaxed">
        Conoce a los talentosos artistas que dan vida a tus ideas. Cada uno con su estilo único y años de experiencia.
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 md:gap-10 mb-16">
      {artistas.map((artista, index) => (
        <ArtistaCard
          artista={artista}
          delay={(index * 0.2 + 0.2).toFixed(1)}
        />
      ))}
    </div>

    <!-- Call to Action -->
    <div class="text-center scroll-animate" data-animation="fadeInUp" data-delay={(artistas.length * 0.2 + 0.2).toFixed(1)}>
      <Heading level={3} size="2xl" variant="primary" class="mb-6 text-white">
        ¿Listo para trabajar con nosotros?
      </Heading>
      <p class="text-xl text-gray-300 mb-8 max-w-2xl mx-auto">
        Nuestros artistas están listos para convertir tu visión en realidad. Agenda una consulta y descubre cuál es el artista perfecto para tu próximo tatuaje.
      </p>
      <Button href="/artistas" variant="primary" size="lg" class="hover:scale-105 transform"> {/* Asumiendo que el botón lleva a una página de equipo o similar */}
        Conoce a Nuestro Equipo
      </Button>
    </div>
  </div>
</section>


