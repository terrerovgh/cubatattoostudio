---
// Layout for Cuba Tattoo Studio
import LoadingScreen from '../components/LoadingScreen.astro';

export interface Props {
  title?: string;
}

const { title = "Cuba Tattoo Studio - Arte Corporal Profesional" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="description" content="Cuba Tattoo Studio - Arte corporal profesional en Cuba. Diseños únicos, técnicas avanzadas y la mejor experiencia en tatuajes." />
    <meta name="keywords" content="tatuajes, tattoo, Cuba, arte corporal, diseños únicos, tattoo studio" />
    <meta property="og:title" content="Cuba Tattoo Studio - Arte Corporal Profesional" />
    <meta property="og:description" content="Descubre el arte del tatuaje en Cuba Tattoo Studio. Diseños únicos y técnicas profesionales." />
    <meta property="og:type" content="website" />
    <title>Cuba Tattoo Studio - Arte Corporal Profesional</title>
  </head>
  <body>
    <!-- Loading Screen -->
    <LoadingScreen />
    
    <!-- Global Animated Background System -->
    <div id="global-background" class="fixed inset-0 z-0">
      <!-- Black & White Image (bottom layer) -->
      <img 
        id="global-bg-bw"
        src="/hero-tattoo-background.jpeg" 
        alt="Cuba Tattoo Studio Background Black and White" 
        class="w-full h-full object-cover scale-110 absolute inset-0"
        loading="eager"
        fetchpriority="high"
      />
      <!-- Color Image (top layer) -->
      <img 
        id="global-bg-color"
        src="/hero-tattoo-background-color.jpeg" 
        alt="Cuba Tattoo Studio Background Color" 
        class="w-full h-full object-cover scale-110 absolute inset-0 opacity-0"
        loading="eager"
        fetchpriority="high"
      />
      <div class="absolute inset-0 bg-black/40 z-10"></div>
      <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-transparent to-black/60 z-10"></div>
    </div>

    <!-- Page Content -->
    <div id="main-content" class="relative z-20 opacity-0">
      <slot />
    </div>
    
    <script>
      import { gsap } from "gsap"
      import { ScrollTrigger } from "gsap/ScrollTrigger"
      
      // Registrar plugins globalmente
      gsap.registerPlugin(ScrollTrigger)
      
      let isInitialized = false
      let globalBackgroundTl = null
      
      // Listen for loading complete event
      window.addEventListener('loadingComplete', () => {
        const mainContent = document.getElementById('main-content');
        if (mainContent) {
          gsap.to(mainContent, {
            opacity: 1,
            duration: 1,
            ease: "power2.out",
            onComplete: () => {
              initStudio();
            }
          });
        }
      });
      
      function initStudio() {
        try {
          // Configuración inicial
          gsap.set("body", { visibility: "visible" })
          
          // Configurar ScrollTrigger
          ScrollTrigger.config({
            autoRefreshEvents: "visibilitychange,DOMContentLoaded,load",
            ignoreMobileResize: true
          })
          
          // Inicializar sistema de fondo global
          initGlobalBackground()
          
          // Navegación suave
          setupSmoothNavigation()
          
          // Animaciones automáticas
          setupAutoAnimations()
          
          // Manejar redimensionamiento
          setupResizeHandler()
          
          isInitialized = true
          console.log("Cuba Tattoo Studio initialized successfully")
          
        } catch (error) {
          console.error("Error initializing:", error)
        }
      }

      function initGlobalBackground() {
        const bgElements = {
          bwImage: document.querySelector('#global-bg-bw'),
          colorImage: document.querySelector('#global-bg-color'),
          container: document.querySelector('#global-background')
        }

        if (!bgElements.bwImage || !bgElements.colorImage) {
          console.warn("Global background elements not found")
          return
        }

        // === ANIMACIÓN CONTINUA DE ZOOM (12 segundos por ciclo) ===
        gsap.to([bgElements.bwImage, bgElements.colorImage], {
          scale: 1.2,
          duration: 6,
          ease: "power2.inOut",
          yoyo: true,
          repeat: -1,
          repeatDelay: 0
        })

        // === TRANSICIÓN CONTINUA DE COLOR BASADA EN SCROLL ===
        
        // Dividir la página en secciones para diferentes efectos
        const sections = document.querySelectorAll('section, main, div[id]')
        
        sections.forEach((section, index) => {
          const isEven = index % 2 === 0
          
          ScrollTrigger.create({
            trigger: section,
            start: "top center",
            end: "bottom center",
            onEnter: () => {
              // Alternar entre B&N y color basado en la sección
              gsap.to(bgElements.colorImage, {
                opacity: isEven ? 1 : 0,
                duration: 2,
                ease: "power2.inOut"
              })
              
              // Agregar un sutil cambio de filtro para más dinamismo
              gsap.to(bgElements.bwImage, {
                filter: isEven ? "contrast(1) brightness(1)" : "contrast(1.1) brightness(0.95)",
                duration: 2,
                ease: "power2.inOut"
              })
            },
            onEnterBack: () => {
              // Mismo efecto al volver hacia arriba
              gsap.to(bgElements.colorImage, {
                opacity: isEven ? 1 : 0,
                duration: 2,
                ease: "power2.inOut"
              })
              
              gsap.to(bgElements.bwImage, {
                filter: isEven ? "contrast(1) brightness(1)" : "contrast(1.1) brightness(0.95)",
                duration: 2,
                ease: "power2.inOut"
              })
            },
            markers: false
          })
        })

        // === PARALLAX SUAVE DURANTE SCROLL ===
        gsap.to([bgElements.bwImage, bgElements.colorImage], {
          yPercent: -20,
          ease: "none",
          scrollTrigger: {
            trigger: "body",
            start: "top top",
            end: "bottom top",
            scrub: 1.5,
            markers: false
          }
        })

        // === ENTRADA INICIAL CINEMATOGRÁFICA ===
        gsap.fromTo([bgElements.bwImage, bgElements.colorImage], 
          { scale: 1.15, opacity: 0 },
          { 
            scale: 1.1, 
            opacity: 1,
            duration: 3, 
            ease: "power2.out",
            stagger: 0.2
          }
        )

        // Transición inicial de color después de 2 segundos
        gsap.to(bgElements.colorImage, {
          opacity: 1,
          duration: 3,
          delay: 2,
          ease: "power2.inOut"
        })

        console.log("Global background system initialized")
      }
      
      function setupSmoothNavigation() {
        document.addEventListener('click', (e) => {
          const target = e.target as HTMLElement
          if (!target) return
          
          const link = target.closest('a[href^="#"]') as HTMLAnchorElement
          if (!link) return
          
          e.preventDefault()
          const targetId = link.getAttribute('href')?.substring(1)
          const targetElement = targetId ? document.getElementById(targetId) : null
          
          if (targetElement) {
            gsap.to(window, {
              duration: 1.2,
              scrollTo: {
                y: targetElement,
                offsetY: 80
              },
              ease: "power2.inOut"
            })
          }
        })
      }
      
      function setupAutoAnimations() {
        // Elementos con clase .scroll-animate
        const scrollElements = document.querySelectorAll('.scroll-animate')
        scrollElements.forEach((element, index) => {
          const htmlElement = element as HTMLElement
          const animationType = htmlElement.dataset.animation || 'fadeIn'
          const delay = htmlElement.dataset.delay ? parseFloat(htmlElement.dataset.delay) : index * 0.1
          
          let fromVars = {}
          switch(animationType) {
            case 'fadeIn':
              fromVars = { y: 30, opacity: 0 }
              break
            case 'slideInLeft':
              fromVars = { x: -50, opacity: 0 }
              break
            case 'slideInRight':
              fromVars = { x: 50, opacity: 0 }
              break
            case 'scaleIn':
              fromVars = { scale: 0.8, opacity: 0 }
              break
            default:
              fromVars = { y: 30, opacity: 0 }
          }
          
          gsap.fromTo(element, fromVars, {
            y: 0,
            x: 0,
            scale: 1,
            opacity: 1,
            duration: 0.8,
            delay,
            ease: "power2.out",
            scrollTrigger: {
              trigger: element,
              start: "top 80%",
              end: "top 20%", // Más tiempo visible en pantalla
              toggleActions: "play none none reverse",
              markers: true // Cambiar a true para debug
            }
          })
        })
        
        // Debug console logs
        console.log("GSAP Debug Info:")
        console.log("- GSAP version:", gsap.version)
        console.log("- ScrollTrigger available:", !!ScrollTrigger)
        console.log("- Elements with .scroll-animate:", scrollElements.length)
        console.log("- Animation system initialized")
        
        // Registrar todos los triggers para debug
        setTimeout(() => {
          const triggers = ScrollTrigger.getAll()
          console.log("- Active ScrollTriggers:", triggers.length)
          triggers.forEach((trigger, index) => {
            console.log(`  ${index + 1}. Trigger for:`, trigger.trigger)
          })
        }, 1000)
      }
      
      function setupResizeHandler() {
        let resizeTimer: number
        window.addEventListener('resize', () => {
          clearTimeout(resizeTimer)
          resizeTimer = window.setTimeout(() => {
            ScrollTrigger.refresh()
          }, 250)
        })
      }
      
      function refreshAnimations() {
        if (isInitialized) {
          ScrollTrigger.refresh()
        }
      }
      
      // Inicializar
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initStudio)
      } else {
        initStudio()
      }
      
      // Para navegación de Astro
      document.addEventListener('astro:page-load', () => {
        if (isInitialized) {
          refreshAnimations()
        } else {
          initStudio()
        }
      })
      
      // Exponer funciones para debugging
      ;(window as any).CubaTattooStudio = {
        refresh: refreshAnimations,
        init: initStudio
      }
    </script>
  </body>
</html>

<style is:global>
  @import "tailwindcss";

  @theme {
    --font-sans: system-ui, sans-serif;

    --animate-bounce-pulse: bounce-pulse 2s ease-in-out infinite;
  }

  @keyframes bounce-pulse {
    0% {
      transform: translateY(0);
      scale: 0.8;
      opacity: 0.8;
    }

    50% {
      transform: translateY(-5px);
      opacity: 1;
      scale: 1;
    }

    100% {
      transform: translateY(0);
      scale: 0.8;
      opacity: 0.8;
    }
  }

  html,
  body {
    background: #000000; /* Fallback while images load */
    min-height: 100vh;
    overflow-x: hidden;
    overscroll-behavior: none;
    color: white;
    margin: 0;
    width: 100%;
    scroll-behavior: smooth;
  }

  /* Global Background Animation System */
  #global-background {
    will-change: transform;
    contain: layout style paint;
    pointer-events: none; /* Allow clicks to pass through */
  }

  #global-bg-bw,
  #global-bg-color {
    will-change: transform, opacity, filter;
    image-rendering: -webkit-optimize-contrast;
    image-rendering: optimize-contrast;
    backface-visibility: hidden;
    transform: translateZ(0);
  }

  /* Continuous zoom animation base */
  .zoom-cycle {
    animation: continuousZoom 12s ease-in-out infinite;
  }

  @keyframes continuousZoom {
    0%, 100% { 
      transform: scale(1.1) translateZ(0); 
    }
    50% { 
      transform: scale(1.2) translateZ(0); 
    }
  }

  /* Color transition animation base */
  .color-cycle {
    animation: colorTransition 12s ease-in-out infinite;
  }

  @keyframes colorTransition {
    0%, 100% { 
      opacity: 0; 
    }
    50% { 
      opacity: 1; 
    }
  }

  /* Scroll-triggered variations */
  .color-cycle-reverse {
    animation: colorTransitionReverse 12s ease-in-out infinite;
  }

  @keyframes colorTransitionReverse {
    0%, 100% { 
      opacity: 1; 
    }
    50% { 
      opacity: 0; 
    }
  }

  /* Optimize image loading */
  #global-bg-bw,
  #global-bg-color {
    content-visibility: auto;
    contain-intrinsic-size: 1920px 1080px;
  }

  /* Loading screen optimization */
  #main-content {
    transition: opacity 1s ease-out;
  }
  
  /* Prevent flash of unstyled content */
  body {
    visibility: hidden;
  }
  
  body.loaded {
    visibility: visible;
  }

  html {
    scroll-behavior: smooth;
  }

  /* Mejoras para formularios */
  input, textarea, select {
    -webkit-appearance: none;
    -moz-appearance: none;
    appearance: none;
  }

  /* Ocultar elementos antes de animar */
  .scroll-animate {
    opacity: 0;
    transform: translateY(30px);
  }

  /* Estados de elementos animados */
  .gsap-animated {
    opacity: 1;
    transform: translateY(0);
  }

  /* Mejoras para scroll suave */
  html {
    scroll-padding-top: 2rem;
  }

  /* Optimizaciones de rendimiento para animaciones */
  .will-animate {
    will-change: transform, opacity;
  }

  /* Transiciones suaves para estados hover */
  .smooth-transition {
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* Efectos hover personalizados */
  .hover-glow:hover {
    box-shadow: 0 0 20px rgba(251, 191, 36, 0.5);
    transition: box-shadow 0.3s ease;
  }

  /* Scrollbar personalizada */
  ::-webkit-scrollbar {
    width: 8px;
  }

  ::-webkit-scrollbar-track {
    background: #111;
  }

  ::-webkit-scrollbar-thumb {
    background: #fbbf24;
    border-radius: 4px;
  }

  ::-webkit-scrollbar-thumb:hover {
    background: #f59e0b;
  }
</style>
