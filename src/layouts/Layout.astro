---
// Layout for Cuba Tattoo Studio
import LoadingScreen from '../components/organisms/LoadingScreen.astro';
import Navigation from '../components/organisms/Navigation.astro';
import Footer from '../components/organisms/Footer.astro';

export interface Props {
  title?: string;
}

const { title = "Cuba Tattoo Studio - Arte Corporal Profesional" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="description" content="Cuba Tattoo Studio - Arte corporal profesional en Cuba. Diseños únicos, técnicas avanzadas y la mejor experiencia en tatuajes." />
    <meta name="keywords" content="tatuajes, tattoo, Cuba, arte corporal, diseños únicos, tattoo studio" />
    <meta property="og:title" content="Cuba Tattoo Studio - Arte Corporal Profesional" />
    <meta property="og:description" content="Descubre el arte del tatuaje en Cuba Tattoo Studio. Diseños únicos y técnicas profesionales." />
    <meta property="og:type" content="website" />
    <title>Cuba Tattoo Studio - Arte Corporal Profesional</title>
  </head>
  <body>
    <!-- Loading Screen -->
    <LoadingScreen />

    <Navigation />

    <!-- Page Content -->
    <div id="main-content" class="relative z-20 opacity-0 pt-16">
      <slot />
    </div>

    <Footer />

    <!-- Particles Background Container -->
    <div id="container" style="position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: -1;"></div>
    
    <!-- GSAP CDN -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js" is:inline></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js" is:inline></script>
    
    <!-- Script principal -->
    <script src="/gsap-tattoo.js" is:inline></script>
    <script type="module" src="/scripts/interactive-particles.js"></script>

    <script>
      document.addEventListener('DOMContentLoaded', () => {
        const mainContent = document.getElementById('main-content');
        console.log('Estado de #main-content:', mainContent?.className);
      });
    </script>
  </body>
</html>

<style is:global>
  @import "tailwindcss";

  @theme {
    --font-sans: system-ui, sans-serif;

    --animate-bounce-pulse: bounce-pulse 2s ease-in-out infinite;
  }

  @keyframes bounce-pulse {
    0% {
      transform: translateY(0);
      scale: 0.8;
      opacity: 0.8;
    }

    50% {
      transform: translateY(-5px);
      opacity: 1;
      scale: 1;
    }

    100% {
      transform: translateY(0);
      scale: 0.8;
      opacity: 0.8;
    }
  }

  html,
  body {
    background: #ffffff; /* Fallback while images load */
    min-height: 100vh;
    overflow-x: hidden;
    overscroll-behavior: none;
    color: black;
    margin: 0;
    width: 100%;
    scroll-behavior: smooth;
  }

  /* Optimize image loading */
  #global-bg-bw,
  #global-bg-color {
    content-visibility: auto;
    contain-intrinsic-size: 1920px 1080px;
  }

  /* Loading screen optimization */
  #main-content {
    transition: opacity 1s ease-out;
  }
  
  /* Prevent flash of unstyled content */
  body {
    visibility: hidden;
  }
  
  body.loaded {
    visibility: visible;
  }

  html {
    scroll-behavior: smooth;
  }

  /* Mejoras para formularios */
  input, textarea, select {
    -webkit-appearance: none;
    -moz-appearance: none;
    appearance: none;
  }

  /* Ocultar elementos antes de animar */
  .scroll-animate {
    opacity: 0;
    transform: translateY(30px);
  }

  /* Estados de elementos animados */
  .gsap-animated {
    opacity: 1;
    transform: translateY(0);
  }

  /* Mejoras para scroll suave */
  html {
    scroll-padding-top: 2rem;
  }

  /* Optimizaciones de rendimiento para animaciones */
  .will-animate {
    will-change: transform, opacity;
  }

  /* Transiciones suaves para estados hover */
  .smooth-transition {
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* Efectos hover personalizados */
  .hover-glow:hover {
    box-shadow: 0 0 20px rgba(251, 191, 36, 0.5);
    transition: box-shadow 0.3s ease;
  }

  /* Scrollbar personalizada */
  ::-webkit-scrollbar {
    width: 8px;
  }

  ::-webkit-scrollbar-track {
    background: #f1f1f1;
  }

  ::-webkit-scrollbar-thumb {
    background: #888;
    border-radius: 4px;
  }

  ::-webkit-scrollbar-thumb:hover {
    background: #555;
  }
</style>

<style>
      html, body {
        height: 100%;
        margin: 0;
        padding: 0;
      }

      body {
        background: url('/image.png') no-repeat center center fixed !important;
        background-size: cover !important;
        animation: zoomOut 30s infinite linear;
      }

      @keyframes zoomOut {
        0% {
          transform: scale(1);
        }
        100% {
          transform: scale(1.1);
        }
      }
    </style>
