---
import Layout from "../../../layouts/Layout.astro";
import AdminGuard from "../../../components/admin/AdminGuard";
import DashboardLayout from "../../../layouts/DashboardLayout";
import ArtistForm from "../../../components/admin/artists/ArtistForm";

export const prerender = false;

const { id } = Astro.params;
---

<Layout title="Edit Artist - Cuba Tattoo Studio">
    <AdminGuard client:only="react">
        <DashboardLayout client:only="react" title="Edit Artist">
            <ArtistForm client:load artistId={id} />
        </DashboardLayout>
    </AdminGuard>
</Layout>
