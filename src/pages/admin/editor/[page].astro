---
import DashboardLayout from "../../../layouts/DashboardLayout";
import VisualEditor from "../../../components/admin/editor/VisualEditor";
import Layout from "../../../layouts/Layout.astro";
import AdminGuard from "../../../components/admin/AdminGuard";

export const prerender = false;

const { page } = Astro.params;

if (!page) {
    return Astro.redirect("/admin/dashboard");
}
---

<Layout title={`Edit ${page.charAt(0).toUpperCase() + page.slice(1)} | Cuba Tattoo Studio`}>
    <AdminGuard client:only="react">
        <DashboardLayout
            client:only="react"
            title={`Edit ${page.charAt(0).toUpperCase() + page.slice(1)}`}
        >
            <VisualEditor client:only="react" pageId={page} section={page} />
        </DashboardLayout>
    </AdminGuard>
</Layout>
