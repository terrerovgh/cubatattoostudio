---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import BookingForm from '../components/BookingForm.astro';
import Heading from '../components/Heading.astro';
---

<Layout title="Reservar Cita - Cuba Tattoo Studio">
  <Header />
  <main class="pt-24">
    <!-- Page Header -->
    <section class="py-20 bg-gradient-to-r from-red-600 to-red-800 text-white">
      <div class="container mx-auto px-4 text-center">
        <Heading level={1} class="mb-6 text-white">
          Reserva tu Cita
        </Heading>
        <p class="text-xl text-red-100 max-w-3xl mx-auto">
          Estamos emocionados de ayudarte a crear tu próxima obra de arte. 
          Completa el formulario y nos pondremos en contacto contigo pronto.
        </p>
      </div>
    </section>

    <!-- Booking Form -->
    <BookingForm />

    <!-- Information Section -->
    <section class="py-20 bg-gray-50">
      <div class="container mx-auto px-4">
        <div class="max-w-4xl mx-auto">
          <Heading level={2} class="text-center mb-12">
            Información Importante
          </Heading>
          
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <div class="bg-white p-6 rounded-lg shadow-sm">
              <h3 class="text-xl font-semibold mb-4 text-red-600">Proceso de Reserva</h3>
              <ul class="space-y-2 text-gray-700">
                <li>• Envía el formulario con todos los detalles</li>
                <li>• Te contactaremos en 24-48 horas</li>
                <li>• Programamos una consulta gratuita</li>
                <li>• Discutimos el diseño y presupuesto</li>
                <li>• Agendamos la cita para tu tatuaje</li>
              </ul>
            </div>

            <div class="bg-white p-6 rounded-lg shadow-sm">
              <h3 class="text-xl font-semibold mb-4 text-red-600">Preparación</h3>
              <ul class="space-y-2 text-gray-700">
                <li>• Trae referencias e ideas claras</li>
                <li>• Evita alcohol 24h antes</li>
                <li>• Come bien antes de la sesión</li>
                <li>• Usa ropa cómoda y apropiada</li>
                <li>• Hidrátate bien los días previos</li>
              </ul>
            </div>

            <div class="bg-white p-6 rounded-lg shadow-sm">
              <h3 class="text-xl font-semibold mb-4 text-red-600">Política de Depósito</h3>
              <ul class="space-y-2 text-gray-700">
                <li>• Depósito del 30% para reservar</li>
                <li>• No reembolsable por cancelaciones</li>
                <li>• Se aplica al costo final del tatuaje</li>
                <li>• Reprogramación hasta 48h antes</li>
              </ul>
            </div>

            <div class="bg-white p-6 rounded-lg shadow-sm">
              <h3 class="text-xl font-semibold mb-4 text-red-600">Cuidados Post-Tatuaje</h3>
              <ul class="space-y-2 text-gray-700">
                <li>• Instrucciones detalladas incluidas</li>
                <li>• Productos de cuidado disponibles</li>
                <li>• Seguimiento durante la sanación</li>
                <li>• Retoques gratuitos si es necesario</li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
