---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ArtistDavid from '../components/ArtistDavid.astro';
import ArtistNina from '../components/ArtistNina.astro';
import ArtistKarli from '../components/ArtistKarli.astro';
import Heading from '../components/Heading.astro';
---

<Layout title="Nuestros Artistas - Cuba Tattoo Studio">
  <Header />
  <main class="pt-24">
    <!-- Page Header -->
    <section class="py-20 bg-gradient-to-r from-gray-900 to-black text-white">
      <div class="container mx-auto px-4 text-center">
        <Heading level={1} class="mb-6 text-white">
          Nuestros Artistas
        </Heading>
        <p class="text-xl text-gray-300 max-w-3xl mx-auto">
          Conoce a los talentosos profesionales que dan vida a tus ideas. 
          Cada uno con su estilo único y años de experiencia en el arte del tatuaje.
        </p>
      </div>
    </section>

    <!-- Artists Sections -->
    <ArtistDavid />
    <ArtistNina />
    <ArtistKarli />

    <!-- Call to Action -->
    <section class="py-20 bg-red-600 text-white">
      <div class="container mx-auto px-4 text-center">
        <Heading level={2} class="mb-6 text-white">
          ¿Listo para tu próximo tatuaje?
        </Heading>
        <p class="text-xl mb-8 text-red-100">
          Reserva una consulta gratuita con cualquiera de nuestros artistas
        </p>
        <a 
          href="/booking" 
          class="inline-flex items-center px-8 py-4 bg-white text-red-600 font-semibold rounded-lg hover:bg-gray-100 transition-colors"
        >
          Reservar Consulta
        </a>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
