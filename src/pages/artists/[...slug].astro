import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import { supabase } from '../../lib/supabase';
import { getArtistBySlug, getWorksByArtistId } from '../../lib/supabase-helpers';

type DbArtist = {
    id: string;
    slug: string;
    name: string;
    specialty: string;
    bio: string;
    avatar_url: string;
    social?: { instagram?: string };
    stats?: Array<{ label: string; value: string }>;
};

export async function getStaticPaths() {
    // First, try to get artists from Supabase
    const { data: dbArtists, error } = await supabase
        .from('artists')
        .select('*')
        .eq('is_active', true);

    if (!error && dbArtists && dbArtists.length > 0) {
        // Use database artists
        return dbArtists.map((artist: any) => ({
            params: { slug: artist.slug },
            props: { artist, isDbArtist: true },
        }));
    }

    return [];
}

type Props = {
    artist?: DbArtist;
    isDbArtist: boolean;
};

// In SSR mode, getStaticPaths is ignored, so we need to fetch data from params
const { slug } = Astro.params;
const propsFromStaticPaths = Astro.props as Props;

// Prepare artist data based on source
let artistData: any;
let works: any[] = [];
let galleryImages: string[] = [];
let ContentComponent: any = null;
let isDbArtist = propsFromStaticPaths.isDbArtist;

// Check if we have props from getStaticPaths (SSG mode) or need to fetch (SSR mode)
if (propsFromStaticPaths.artist) {
    // SSG mode - use props from getStaticPaths
    const { artist } = propsFromStaticPaths;

    if (isDbArtist && artist) {
        // Database artist
        artistData = artist;
        const dbWorks = await getWorksByArtistId(artist.id);
        works = dbWorks;
        // Map works to include necessary data for display and linking
        galleryImages = dbWorks
            .map((work: any) => ({
                src: work.image_url || (work.images && work.images[0]),
                title: work.title,
                slug: work.slug,
                id: work.id,
            }))
            .filter((img: any) => img.src);
    }
} else {
    // SSR mode - fetch data based on slug
    if (!slug) {
        return Astro.redirect('/404');
    }

    // Try to fetch from database first
    const dbArtist = await getArtistBySlug(slug);

    if (dbArtist) {
        isDbArtist = true;
        artistData = dbArtist;
        const dbWorks = await getWorksByArtistId(dbArtist.id);
        works = dbWorks;
        galleryImages = dbWorks
            .map((work: any) => ({
                src: work.image_url || (work.images && work.images[0]),
                title: work.title,
                slug: work.slug,
                id: work.id,
            }))
            .filter((img: any) => img.src);
    } else {
        return Astro.redirect('/404');
    }
}
---

<Layout title={`${artistData.name} | Cuba Tattoo Studio`}>
    <Navbar />

    <main id="artist-content" class="pt-32 pb-20 min-h-screen fade-enter fade-enter-active">
        <div class="max-w-7xl mx-auto px-6">
            <!-- Header Section -->
            <div class="flex flex-col lg:flex-row gap-12 lg:gap-24 mb-24">
                <!-- Text Info -->
                <div class="flex-1 order-2 lg:order-1 pt-8 reveal-hidden">
                    <div
                        class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-neutral-100 dark:bg-neutral-900 text-neutral-600 dark:text-neutral-400 text-[10px] uppercase tracking-widest font-semibold mb-6"
                    >
                        <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
                        Booking Open
                    </div>

                    <h1
                        class="text-6xl md:text-8xl font-medium tracking-tighter text-neutral-900 dark:text-white mb-2"
                    >
                        {artistData.name}.
                    </h1>
                    <h2 class="text-xl text-neutral-500 dark:text-neutral-400 font-medium mb-8">
                        {
                            artistData.specialties
                                ? Array.isArray(artistData.specialties)
                                    ? artistData.specialties.join(' & ')
                                    : artistData.specialty || artistData.specialties
                                : artistData.specialty || ''
                        }
                    </h2>

                    <p
                        class="text-lg md:text-xl font-light leading-relaxed text-neutral-600 dark:text-neutral-300 mb-10 max-w-xl"
                    >
                        {artistData.bio}
                    </p>

                    <!-- Stats Grid -->
                    {
                        artistData.stats && (
                            <div class="grid grid-cols-3 gap-8 border-y border-neutral-200 dark:border-neutral-800 py-8 mb-10">
                                {artistData.stats.map((stat: any) => (
                                    <div>
                                        <div class="text-[10px] uppercase tracking-widest text-neutral-500 mb-1">
                                            {stat.label}
                                        </div>
                                        <div class="text-lg font-medium text-neutral-900 dark:text-white">
                                            {stat.value}
                                        </div>
                                    </div>
                                ))}
                            </div>
                        )
                    }

                    <div class="flex items-center gap-4">
                        <a
                            href="#booking"
                            class="inline-flex items-center justify-center h-12 px-8 rounded-full bg-neutral-900 dark:bg-white text-white dark:text-black font-medium text-sm transition-transform hover:scale-105 active:scale-95"
                        >
                            Request Consultation
                        </a>
                        {
                            artistData.social?.instagram && (
                                <a
                                    href={artistData.social.instagram}
                                    target="_blank"
                                    rel="noopener noreferrer"
                                    class="inline-flex items-center justify-center h-12 w-12 rounded-full border border-neutral-200 dark:border-neutral-800 text-neutral-900 dark:text-white hover:bg-neutral-50 dark:hover:bg-neutral-900 transition-colors"
                                >
                                    <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        width="24"
                                        height="24"
                                        viewBox="0 0 24 24"
                                        fill="none"
                                        stroke="currentColor"
                                        stroke-width="2"
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        class="lucide lucide-instagram w-5 h-5"
                                    >
                                        <>
                                            <rect
                                                width="20"
                                                height="20"
                                                x="2"
                                                y="2"
                                                rx="5"
                                                ry="5"
                                            />
                                            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z" />
                                            <line x1="17.5" x2="17.51" y1="6.5" y2="6.5" />
                                        </>
                                    </svg>
                                </a>
                            )
                        }
                    </div>
                </div>

                <!-- Portrait -->
                <div
                    class="w-full lg:w-[400px] xl:w-[480px] order-1 lg:order-2 shrink-0 reveal-hidden"
                    style="transition-delay: 0.2s;"
                >
                    <div
                        class="relative aspect-[4/5] rounded-2xl overflow-hidden bg-neutral-100 dark:bg-neutral-800"
                    >
                        <img
                            src={artistData.avatar_url}
                            class="absolute inset-0 w-full h-full object-cover filter grayscale hover:grayscale-0 transition-all duration-1000"
                            alt={artistData.name}
                        />
                        <div
                            class="absolute inset-0 border border-black/5 dark:border-white/10 rounded-2xl z-10 pointer-events-none"
                        >
                        </div>
                    </div>
                </div>
            </div>

            <!-- Portfolio Grid -->
            <div class="mb-12 flex items-center justify-between reveal-hidden">
                <h3 class="text-2xl font-medium tracking-tight">Selected Works</h3>
                <span class="text-xs text-neutral-500 font-mono"
                    >01 — {
                        galleryImages.length < 10
                            ? '0' + galleryImages.length
                            : galleryImages.length
                    }</span
                >
            </div>

            {
                galleryImages.length > 0 ? (
                    <div class="columns-1 md:columns-2 lg:columns-3 gap-6 space-y-6">
                        {galleryImages.map((item: any, index: number) => (
                            <div
                                class="mb-6 break-inside-avoid group relative overflow-hidden rounded-xl bg-neutral-100 dark:bg-neutral-800 cursor-pointer reveal-hidden"
                                style={`transition-delay: ${0.1 * (index % 3)}s;`}
                            >
                                <a href={`/works/${item.slug}`} class="block relative">
                                    <img
                                        src={item.src}
                                        class="w-full h-auto object-cover transition-transform duration-500 group-hover:scale-105"
                                        alt={item.title || 'Portfolio Piece'}
                                    />
                                    <div class="absolute inset-0 bg-black/0 group-hover:bg-black/20 transition-colors duration-300 flex items-center justify-center opacity-0 group-hover:opacity-100">
                                        <span class="text-white font-medium px-4 py-2 bg-black/50 rounded-full backdrop-blur-sm">
                                            View Details
                                        </span>
                                    </div>
                                </a>
                            </div>
                        ))}
                    </div>
                ) : (
                    <div class="text-center py-12 text-neutral-500">
                        <p>No works available yet.</p>
                    </div>
                )
            }

            {
                !isDbArtist && ContentComponent && (
                    <div class="prose prose-invert max-w-none mt-20">
                        <ContentComponent />
                    </div>
                )
            }
        </div>
    </main>

    <Footer />
</Layout>

<style>
    :root {
        --reveal-distance: 30px;
        --reveal-duration: 0.8s;
    }

    /* Smooth fade transition for content switching */
    .fade-enter {
        opacity: 0;
        transform: translateY(10px);
    }
    .fade-enter-active {
        opacity: 1;
        transform: translateY(0);
        transition:
            opacity 0.4s ease,
            transform 0.4s ease;
    }

    /* Custom scrollbar */
    ::-webkit-scrollbar {
        width: 8px;
    }
    ::-webkit-scrollbar-track {
        background: transparent;
    }
    ::-webkit-scrollbar-thumb {
        background-color: rgba(100, 100, 100, 0.3);
        border-radius: 20px;
    }
</style>

<script>
    // Add fade-enter-active class on load
    document.addEventListener('DOMContentLoaded', () => {
        const content = document.getElementById('artist-content');
        if (content) {
            content.classList.add('fade-enter-active');
        }
    });
</script>
