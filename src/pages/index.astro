---
import Layout from '../layouts/Layout.astro';
import HeroSection from '../components/organisms/HeroSection.astro';
import ServicesSection from '../components/organisms/ServicesSection.astro';
import GallerySection from '../components/organisms/EnhancedGallery.astro';
import ArtistsSection from '../components/organisms/ArtistSection.astro';
import ContactSection from '../components/organisms/BookingSection.astro';
import Footer from '../components/organisms/Footer.astro';
import { useTranslations } from '../i18n/index.ts';

const lang = 'en'; // Default language for index
const t = useTranslations(lang);
---

<Layout title={t('pages.home.title')}>
  <HeroSection />
  <ServicesSection />
  <GallerySection />
  <ArtistsSection />
  <ContactSection />
  <Footer />
</Layout>


