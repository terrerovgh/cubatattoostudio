;f=webp 768w\" sizes=\"(max-width: 768px) 100vw, (max-width: 1200px) 50vw, 33vw\" type=\"image/webp\" data-astro-cid-ljn3pzdo data-astro-source-file=\"/workspaces/cubatattoostudio/src/components/ImageOptimized.astro\" data-astro-source-loc=\"60:8\">  <!-- Imagen fallback --> <img src=\"/artists/nina/artist-nina.jpg?w=400&#38;q=80&#38;f=webp\" srcset=\"/artists/nina/artist-nina.jpg?w=320&#38;q=80&#38;f=webp 320w, /artists/nina/artist-nina.jpg?w=640&#38;q=80&#38;f=webp 640w, /artists/nina/artist-nina.jpg?w=768&#38;q=80&#38;f=webp 768w\" sizes=\"(max-width: 768px) 100vw, (max-width: 1200px) 50vw, 33vw\" alt=\"Nina - Especialista en Tatuajes Tradicionales y Neo-Tradicionales\" width=\"400\" height=\"500\" loading=\"lazy\" decoding=\"async\" class=\"transition-all duration-300 ease-in-out opacity-0 scale-95 w-full h-full object-cover group-hover:scale-110 transition-transform duration-700 ease-out\" data-optimized-image data-astro-cid-g7is3flq=\"true\" data-astro-cid-ljn3pzdo data-astro-source-file=\"/workspaces/cubatattoostudio/src/components/ImageOptimized.astro\" data-astro-source-loc=\"69:4\"> </picture> <script>\n  // Sistema de lazy loading personalizado con IntersectionObserver\n  if ('IntersectionObserver' in window) {\n    const imageObserver = new IntersectionObserver((entries, observer) => {\n      entries.forEach(entry => {\n        if (entry.isIntersecting) {\n          const img = entry.target;\n          \n          // Aplicar animación de entrada\n          img.classList.remove('opacity-0', 'scale-95');\n          img.classList.add('opacity-100', 'scale-100');\n          \n          // Dejar de observar esta imagen\n          observer.unobserve(img);\n        }\n      });\n    }, {\n      rootMargin: '50px 0px',\n      threshold: 0.1\n    });\n\n    // Observar todas las imágenes optimizadas\n    document.addEventListener('DOMContentLoaded', () => {\n      const images = document.querySelectorAll('[data-optimized-image]');\n      images.forEach(img => {\n        if (img.loading === 'lazy') {\n          imageObserver.observe(img);\n        } else {\n          // Para imágenes eager, aplicar animación inmediatamente\n          img.classList.add('opacity-100', 'scale-100');\n        }\n      });\n    });\n  } else {\n    // Fallback para navegadores sin IntersectionObserver\n    document.addEventListener('DOMContentLoaded', () => {\n      const images = document.querySelectorAll('[data-optimized-image]');\n      images.forEach(img => {\n        img.classList.add('opacity-100', 'scale-100');\n      });\n    });\n  }\n</script>  </div> <!-- Content --> <div class=\"absolute bottom-0 left-0 right-0 p-6 md:p-8 z-20\" data-astro-cid-g7is3flq data-astro-source-file=\"/workspaces/cubatattoostudio/src/components/ArtistNina.astro\" data-astro-source-loc=\"30:65\"> <!-- Artist Name --> <h3 class=\"font-bold leading-tight tracking-tight text-2xl md:text-3xl text-white  mb-2\" data-astro-cid-g7is3flq=\"true\" data-astro-cid-u4qoyrkz=\"true\"> \nNina\n </h3>  <!-- Specialty --> <p class=\"text-amber-400 font-semibold text-lg mb-3\" data-astro-cid-g7is3flq data-astro-source-file=\"/workspaces/cubatattoostudio/src/components/ArtistNina.astro\" data-astro-source-loc=\"37:58\">\nTradicional & Neo-Tradicional\n</p> <!-- Description --> <p class=\"text-gray-300 text-sm md:text-base mb-4 line-clamp-3 group-hover:line-clamp-none transition-all duration-300\" data-astro-cid-g7is3flq data-astro-source-file=\"/workspaces/cubatattoostudio/src/components/ArtistNina.astro\" data-astro-source-loc=\"42:125\">\nArtista versátil con 6 años de experiencia especializada en estilos tradicionales y neo-tradicionales. \n      Nina combina técnicas clásicas con toques modernos, creando diseños únicos y vibrantes. \n      Experta en líneas sólidas, colores brillantes y composiciones que destacan.\n</p> <!-- Specialties List --> <div class=\"flex flex-wrap gap-2 mb-4\" data-astro-cid-g7is3flq data-astro-source-file=\"/workspaces/cubatattoostudio/src/components/ArtistNina.astro\" data-astro-source-loc=\"49:44\"> <span class=\"px-3 py-1 bg-amber-400/10 text-amber-400 text-xs rounded-full border border-amber-400/20\" data-astro-cid-g7is3flq data-astro-source-file=\"/workspaces/cubatattoostudio/src/components/ArtistNina.astro\" data-astro-source-loc=\"50:110\">\nTradicional\n</span> <span class=\"px-3 py-1 bg-amber-400/10 text-amber-400 text-xs rounded-full border border-amber-400/20\" data-astro-cid-g7is3flq data-astro-source-file=\"/workspaces/cubatattoostudio/src/components/ArtistNina.astro\" data-astro-source-loc=\"53:110\">\nNeo-Tradicional\n</span> <span class=\"px-3 py-1 bg-amber-400/10 text-amber-400 text-xs rounded-full border border-amber-400/20\" data-astro-cid-g7is3flq data-astro-source-file=\"/workspaces/cubatattoostudio/src/components/ArtistNina.astro\" data-astro-source-loc=\"56:110\">\nColor\n</span> <span class=\"px-3 py-1 bg-amber-400/10 text-amber-400 text-xs rounded-full border border-amber-400/20\" data-astro-cid-g7is3flq data-astro-source-file=\"/workspaces/cubatattoostudio/src/components/ArtistNina.astro\" data-astro-source-loc=\"59:110\">\nIlustrativo\n</span> </div> <!-- Stats --> <div class=\"grid grid-cols-3 gap-4 mb-6 text-center\" data-astro-cid-g7is3flq data-astro-source-file=\"/workspaces/cubatattoostudio/src/components/ArtistNina.astro\" data-astro-source-loc=\"65:58\"> <div data-astro-cid-g7is3flq data-astro-source-file=\"/workspaces/cubatattoostudio/src/components/ArtistNina.astro\" data-astro-source-loc=\"66:12\"> <div class=\"text-amber-400 font-bold text-lg\" data-astro-cid-g7is3flq data-astro-source-file=\"/workspaces/cubatattoostudio/src/components/ArtistNina.astro\" data-astro-source-loc=\"67:55\">6+</div> <div class=\"text-gray-400 text-xs\" data-astro-cid-g7is3flq data-astro-source-file=\"/workspaces/cubatattoostudio/src/components/ArtistNina.astro\" data-astro-source-loc=\"68:44\">Años</div> </div> <div data-astro-cid-g7is3flq data-astro-source-file=\"/workspaces/cubatattoostudio/src/components/ArtistNina.astro\" data-astro-source-loc=\"70:12\"> <div class=\"text-amber-400 font-bold text-lg\" data-astro-cid-g7is3flq data-astro-source-file=\"/workspaces/cubatattoostudio/src/components/ArtistNina.astro\" data-astro-source-loc=\"71:55\">350+</div> <div class=\"text-gray-400 text-xs\" data-astro-cid-g7is3flq data-astro-source-file=\"/workspaces/cubatattoostudio/src/components/ArtistNina.astro\" data-astro-source-loc=\"72:44\">Tatuajes</div> </div> <div data-astro-cid-g7is3flq data-astro-source-file=\"/workspaces/cubatattoostudio/src/components/ArtistNina.astro\" data-astro-source-loc=\"74:12\"> <div class=\"text-amber-400 font-bold text-lg\" data-astro-cid-g7is3flq data-astro-source-file=\"/workspaces/cubatattoostudio/src/components/ArtistNina.astro\" data-astro-source-loc=\"75:55\">★ 4.8</div> <div class=\"text-gray-400 text-xs\" data-astro-cid-g7is3flq data-astro-source-file=\"/workspaces/cubatattoostudio/src/components/ArtistNina.astro\" data-astro-source-loc=\"76:44\">Rating</div> </div> </div> <!-- Action Buttons --> <div class=\"flex gap-3\" data-astro-cid-g7is3flq data-astro-source-file=\"/workspaces/cubatattoostudio/src/components/ArtistNina.astro\" data-astro-source-loc=\"81:29\"> <button type=\"button\" class=\"inline-flex items-center justify-center font-semibold transition-all duration-200 ease-in-out focus:outline-none focus:ring-2 focus:ring-offset-2 disabled:opacity-50 disabled:cursor-not-allowed bg-amber-400 text-black hover:bg-amber-500 focus:ring-amber-400 px-3 py-2 text-sm rounded-md flex-1\" data-astro-cid-g7is3flq=\"true\" data-astro-cid-vnzlvqnm=\"true\"> \nVer Portfolio\n </button>  <button type=\"button\" class=\"inline-flex items-center justify-center font-semibold transition-all duration-200 ease-in-out focus:outline-none focus:ring-2 focus:ring-offset-2 disabled:opacity-50 disabled:cursor-not-allowed border-2 border-amber-400 text-amber-400 hover:bg-amber-400 hover:text-black focus:ring-amber-400 px-3 py-2 text-sm rounded-md flex-1\" data-astro-cid-g7is3flq=\"true\" data-astro-cid-vnzlvqnm=\"true\"> \nReservar Cita\n </button>  </div> </div> <!-- Hover Effects --> <div class=\"absolute inset-0 bg-gradient-to-t from-amber-400/20 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 z-5\" data-astro-cid-g7is3flq data-astro-source-file=\"/workspaces/cubatattoostudio/src/components/ArtistNina.astro\" data-astro-source-loc=\"92:4\"></div> </div>  </div> <div class=\"scroll-animate\" data-animation=\"fadeIn\" data-delay=\"0.6\" data-astro-source-file=\"/workspaces/cubatattoostudio/src/components/ArtistsSection.astro\" data-astro-source-loc=\"30:76\"> <div class=\"artist-card group relative overflow-hidden rounded-2xl bg-gradient-to-br from-gray-900 to-black border border-gray-800 hover:border-amber-400/50 transition-all duration-500 \" data-astro-cid-24mdii3m data-astro-source-file=\"/workspaces/cubatattoostudio/src/components/ArtistKarli.astro\" data-astro-source-loc=\"13:202\"> <!-- Background with overlay --> <div class=\"absolute inset-0 bg-gradient-to-t from-black via-black/50 to-transparent z-10\" data-astro-cid-24mdii3m data-astro-source-file=\"/workspaces/cubatattoostudio/src/components/ArtistKarli.astro\" data-astro-source-loc=\"15:4\"></div> <!-- Artist Image --> <div class=\"relative h-96 md:h-[500px] overflow-hidden\" data-astro-cid-24mdii3m data-astro-source-file=\"/workspaces/cubatattoostudio/src/components/ArtistKarli.astro\" data-astro-source-loc=\"18:59\"> <picture class=\"block\" data-astro-cid-ljn3pzdo data-astro-source-file=\"/workspaces/cubatattoostudio/src/components/ImageOptimized.astro\" data-astro-source-loc=\"49:24\"> <!-- WebP/AVIF para navegadores compatibles --> <source srcset=\"/artists/karli/artist-karli.jpg?w=320&#38;q=80&#38;f=webp 320w, /artists/karli/artist-karli.jpg?w=640&#38;q=80&#38;f=webp 640w, /artists/karli/artist-karli.jpg?w=768&#38;q=80&#38;f=webp 768w\" sizes=\"(max-width: 768px) 100vw, (max-width: 1200px) 50vw, 33vw\" type=\"image/webp\" data-astro-cid-ljn3pzdo data-astro-source-file=\"/workspaces/cubatattoostudio/src/components/ImageOptimized.astro\" data-astro-source-loc=\"60:8\">  <!-- Imagen fallback --> <img src=\"/artists/karli/artist-karli.jpg?w=400&#38;q=80&#38;f=webp\" srcset=\"/artists/karli/artist-karli.jpg?w=320&#38;q=80&#38;f=webp 320w, /artists/karli/artist-karli.jpg?w=640&#38;q=80&#38;f=webp 640w, /artists/karli/artist-karli.jpg?w=768&#38;q=80&#38;f=webp 768w\" sizes=\"(max-width: 768px) 100vw, (max-width: 1200px) 50vw, 33vw\" alt=\"Karli - Especialista en Tatuajes Geométricos y Minimalistas\" width=\"400\" height=\"500\" loading=\"lazy\" decoding=\"async\" class=\"transition-all duration-300 ease-in-out opacity-0 scale-95 w-full h-full object-cover group-hover:scale-110 transition-transform duration-700 ease-out\" data-optimized-image data-astro-cid-24mdii3m=\"true\" data-astro-cid-ljn3pzdo data-astro-source-file=\"/workspaces/cubatattoostudio/src/components/ImageOptimized.astro\" data-astro-source-loc=\"69:4\"> </picture> <script>\n  // Sistema de lazy loading personalizado con IntersectionObserver\n  if ('IntersectionObserver' in window) {\n    const imageObserver = new IntersectionObserver((entries, observer) => {\n      entries.forEach(entry => {\n        if (entry.isIntersecting) {\n          const img = entry.target;\n          \n          // Aplicar animación de entrada\n          img.classList.remove('opacity-0', 'scale-95');\n          img.classList.add('opacity-100', 'scale-100');\n          \n          // Dejar de observar esta imagen\n          observer.unobserve(img);\n        }\n      });\n    }, {\n      rootMargin: '50px 0px',\n      threshold: 0.1\n    });\n\n    // Observar todas las imágenes optimizadas\n    document.addEventListener('DOMContentLoaded', () => {\n      const images = document.querySelectorAll('[data-optimized-image]');\n      images.forEach(img => {\n        if (img.loading === 'lazy') {\n          imageObserver.observe(img);\n        } else {\n          // Para imágenes eager, aplicar animación inmediatamente\n          img.classList.add('opacity-100', 'scale-100');\n        }\n      });\n    });\n  } else {\n    // Fallback para navegadores sin IntersectionObserver\n    document.addEventListener('DOMContentLoaded', () => {\n      const images = document.querySelectorAll('[data-optimized-image]');\n      images.forEach(img => {\n        img.classList.add('opacity-100', 'scale-100');\n      });\n    });\n  }\n</script>  </div> <!-- Content --> <div class=\"absolute bottom-0 left-0 right-0 p-6 md:p-8 z-20\" data-astro-cid-24mdii3m data-astro-source-file=\"/workspaces/cubatattoostudio/src/components/ArtistKarli.astro\" data-astro-source-loc=\"30:65\"> <!-- Artist Name --> <h3 class=\"font-bold leading-tight tracking-tight text-2xl md:text-3xl text-white  mb-2\" data-astro-cid-24mdii3m=\"true\" data-astro-cid-u4qoyrkz=\"true\"> \nKarli\n </h3>  <!-- Specialty --> <p class=\"text-amber-400 font-semibold text-lg mb-3\" data-astro-cid-24mdii3m data-astro-source-file=\"/workspaces/cubatattoostudio/src/components/ArtistKarli.astro\" data-astro-source-loc=\"37:58\">\nGeométrico & Minimalista\n</p> <!-- Description --> <p class=\"text-gray-300 text-sm md:text-base mb-4 line-clamp-3 group-hover:line-clamp-none transition-all duration-300\" data-astro-cid-24mdii3m data-astro-source-file=\"/workspaces/cubatattoostudio/src/components/ArtistKarli.astro\" data-astro-source-loc=\"42:125\">\nEspecialista en diseños geométricos y minimalistas con 5 años de experiencia. \n      Karli crea composiciones precisas y elegantes que combinan matemática y arte. \n      Experta en líneas limpias, patrones complejos y diseños contemporáneos que perduran en el tiempo.\n</p> <!-- Specialties List --> <div class=\"flex flex-wrap gap-2 mb-4\" data-astro-cid-24mdii3m data-astro-source-file=\"/workspaces/cubatattoostudio/src/components/ArtistKarli.astro\" data-astro-source-loc=\"49:44\"> <span class=\"px-3 py-1 bg-amber-400/10 text-amber-400 text-xs rounded-full border border-amber-400/20\" data-astro-cid-24mdii3m data-astro-source-file=\"/workspaces/cubatattoostudio/src/components/ArtistKarli.astro\" data-astro-source-loc=\"50:110\">\nGeométrico\n</span> <span class=\"px-3 py-1 bg-amber-400/10 text-amber-400 text-xs rounded-full border border-amber-400/20\" data-astro-cid-24mdii3m data-astro-source-file=\"/workspaces/cubatattoostudio/src/components/ArtistKarli.astro\" data-astro-source-loc=\"53:110\">\nMinimalista\n</span> <span class=\"px-3 py-1 bg-amber-400/10 text-amber-400 text-xs rounded-full border border-amber-400/20\" data-astro-cid-24mdii3m data-astro-source-file=\"/workspaces/cubatattoostudio/src/components/ArtistKarli.astro\" data-astro-source-loc=\"56:110\">\nLíneas Finas\n</span> <span class=\"px-3 py-1 bg-amber-400/10 text-amber-400 text-xs rounded-full border border-amber-400/20\" data-astro-cid-24mdii3m data-astro-source-file=\"/workspaces/cubatattoostudio/src/components/ArtistKarli.astro\" data-astro-source-loc=\"59:110\">\nContemporáneo\n</span> </div> <!-- Stats --> <div class=\"grid grid-cols-3 gap-4 mb-6 text-center\" data-astro-cid-24mdii3m data-astro-source-file=\"/workspaces/cubatattoostudio/src/components/ArtistKarli.astro\" data-astro-source-loc=\"65:58\"> <div data-astro-cid-24mdii3m data-astro-source-file=\"/workspaces/cubatattoostudio/src/components/ArtistKarli.astro\" data-astro-source-loc=\"66:12\"> <div class=\"text-amber-400 font-bold text-lg\" data-astro-cid-24mdii3m data-astro-source-file=\"/workspaces/cubatattoostudio/src/components/ArtistKarli.astro\" data-astro-source-loc=\"67:55\">5+</div> <div class=\"text-gray-400 text-xs\" data-astro-cid-24mdii3m data-astro-source-file=\"/workspaces/cubatattoostudio/src/components/ArtistKarli.astro\" data-astro-source-loc=\"68:44\">Años</div> </div> <div data-astro-cid-24mdii3m data-astro-source-file=\"/workspaces/cubatattoostudio/src/components/ArtistKarli.astro\" data-astro-source-loc=\"70:12\"> <div class=\"text-amber-400 font-bold text-lg\" data-astro-cid-24mdii3m data-astro-source-file=\"/workspaces/cubatattoostudio/src/components/ArtistKarli.astro\" data-astro-source-loc=\"71:55\">280+</div> <div class=\"text-gray-400 text-xs\" data-astro-cid-24mdii3m data-astro-source-file=\"/workspaces/cubatattoostudio/src/components/ArtistKarli.astro\" data-astro-source-loc=\"72:44\">Tatuajes</div> </div> <div data-astro-cid-24mdii3m data-astro-source-file=\"/workspaces/cubatattoostudio/src/components/ArtistKarli.astro\" data-astro-source-loc=\"74:12\"> <div class=\"text-amber-400 font-bold text-lg\" data-astro-cid-24mdii3m data-astro-source-file=\"/workspaces/cubatattoostudio/src/components/ArtistKarli.astro\" data-astro-source-loc=\"75:55\">★ 4.9</div> <div class=\"text-gray-400 text-xs\" data-astro-cid-24mdii3m data-astro-source-file=\"/workspaces/cubatattoostudio/src/components/ArtistKarli.astro\" data-astro-source-loc=\"76:44\">Rating</div> </div> </div> <!-- Action Buttons --> <div class=\"flex gap-3\" data-astro-cid-24mdii3m data-astro-source-file=\"/workspaces/cubatattoostudio/src/components/ArtistKarli.astro\" data-astro-source-loc=\"81:29\"> <button type=\"button\" class=\"inline-flex items-center justify-center font-semibold transition-all duration-200 ease-in-out focus:outline-none focus:ring-2 focus:ring-offset-2 disabled:opacity-50 disabled:cursor-not-allowed bg-amber-400 text-black hover:bg-amber-500 focus:ring-amber-400 px-3 py-2 text-sm rounded-md flex-1\" data-astro-cid-24mdii3m=\"true\" data-astro-cid-vnzlvqnm=\"true\"> \nVer Portfolio\n </button>  <button type=\"button\" class=\"inline-flex items-center justify-center font-semibold transition-all duration-200 ease-in-out focus:outline-none focus:ring-2 focus:ring-offset-2 disabled:opacity-50 disabled:cursor-not-allowed border-2 border-amber-400 text-amber-400 hover:bg-amber-400 hover:text-black focus:ring-amber-400 px-3 py-2 text-sm rounded-md flex-1\" data-astro-cid-24mdii3m=\"true\" dat