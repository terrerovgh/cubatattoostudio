---
/**
 * Sección de artista con scroll horizontal tipo GTA VI
 * Props:
 *  - name: string (nombre del artista)
 *  - themeColor: string (color de acento CSS)
 *  - videoSrc: string (ruta al video MP4)
 *  - images: string[] (array de rutas de imágenes)
 */
const {
  name = "Artist Name",
  themeColor = "#ffb0c4",
  videoSrc = "https://www.w3schools.com/html/mov_bbb.mp4",
  images = [
    "https://placehold.co/600x800?text=Image+1",
    "https://placehold.co/600x800?text=Image+2",
    "https://placehold.co/600x800?text=Image+3",
  ],
} = Astro.props;

// Generar ID único para la sección
const sectionId = `artist-${name.toLowerCase().replace(/\s+/g, '-')}`;
---

<section 
  id={sectionId}
  class="artist-section" 
  style={`--accent: ${themeColor}`}
>   
  <!-- Título del artista -->
  <div class="artist-header">
    <h2 class="artist-name">
      <span class="name-text">{name}</span>
    </h2>
  </div>

  <!-- Contenido principal -->
  <div class="artist-content">
    <!-- Video (izquierda en desktop, arriba en móvil) -->
    <div class="artist-video-container">
      <div class="video-wrapper">
        <video 
          class="artist-video" 
          src={videoSrc} 
          muted 
          playsinline 
          loop
          preload="auto"
        ></video>
      </div>
    </div>

    <!-- Galería horizontal (derecha en desktop, abajo en móvil) -->
    <div class="artist-gallery-container">
      <div class="artist-gallery">
        {images.map((src, index) => (
          <div class="gallery-item">
            <img 
              src={src} 
              alt={`${name} artwork ${index + 1}`} 
              loading="lazy" 
              class="gallery-image"
            />
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- Indicador de scroll -->
  <div class="scroll-indicator">
    <div class="indicator-line"></div>
    <span>Scroll</span>
  </div>
</section>

<style>
/* Estilos base de la sección */
.artist-section {
  min-height: 100vh;
  width: 100vw;
  position: relative;
  overflow: hidden;
  color: #fff;
  background-color: #000;
  padding: 100px 5vw 60px;
  display: flex;
  flex-direction: column;
}

/* Header con el nombre */
.artist-header {
  position: relative;
  z-index: 10;
  margin-bottom: 5vh;
  padding: 0 2vw;
}

.artist-name {
  font-size: clamp(2.5rem, 8vw, 6rem);
  margin: 0;
  text-transform: uppercase;
  color: var(--accent);
  font-weight: 700;
  line-height: 1;
  letter-spacing: -0.03em;
  opacity: 0;
  transform: translateY(30px);
  will-change: transform, opacity;
}

.name-text {
  display: inline-block;
}

/* Contenedor principal */
.artist-content {
  display: flex;
  flex-direction: column;
  gap: 5vh;
  flex-grow: 1;
  position: relative;
  z-index: 5;
}

/* Estilos del video */
.artist-video-container {
  width: 100%;
  position: relative;
  opacity: 0;
  transform: translateY(50px);
  will-change: transform, opacity;
}

.video-wrapper {
  position: relative;
  width: 100%;
  padding-top: 56.25%; /* 16:9 Aspect Ratio */
  overflow: hidden;
  border-radius: 12px;
  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
}

.artist-video {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  opacity: 0.95;
  transition: opacity 0.5s ease;
}

.artist-video:hover {
  opacity: 1;
}

/* Galería horizontal */
.artist-gallery-container {
  width: 100%;
  overflow: hidden;
  padding: 20px 0 60px;
}

.artist-gallery {
  display: flex;
  gap: 2vw;
  will-change: transform;
  padding-bottom: 20px;
}

.gallery-item {
  flex: 0 0 auto;
  width: 80vw;
  max-width: 400px;
  opacity: 0;
  transform: translateY(30px);
  will-change: transform, opacity;
}

.gallery-image {
  width: 100%;
  height: auto;
  border-radius: 8px;
  box-shadow: 0 5px 15px rgba(0, 0, 0, 0.3);
  transition: transform 0.3s ease, box-shadow 0.3s ease;
}

.gallery-item:hover .gallery-image {
  transform: translateY(-5px);
  box-shadow: 0 15px 30px rgba(0, 0, 0, 0.4);
}

/* Indicador de scroll */
.scroll-indicator {
  position: absolute;
  right: 40px;
  bottom: 40px;
  display: flex;
  align-items: center;
  transform: rotate(90deg) translateX(50%);
  transform-origin: right center;
  color: rgba(255, 255, 255, 0.6);
  font-size: 0.8rem;
  text-transform: uppercase;
  letter-spacing: 2px;
  z-index: 20;
  opacity: 0;
  transition: opacity 0.3s ease;
}

.scroll-indicator.visible {
  opacity: 1;
}

.indicator-line {
  width: 50px;
  height: 1px;
  background: currentColor;
  margin-right: 10px;
  position: relative;
  overflow: hidden;
}

.indicator-line::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, #fff, transparent);
  animation: scrollIndicator 2s infinite;
}

@keyframes scrollIndicator {
  0% { transform: translateX(-100%); }
  100% { transform: translateX(100%); }
}

/* Responsive */
@media (min-width: 1024px) {
  .artist-content {
    flex-direction: row;
    align-items: center;
    gap: 5vw;
  }
  
  .artist-video-container {
    width: 45%;
    padding-top: 0;
  }
  
  .video-wrapper {
    padding-top: 0;
    height: 70vh;
  }
  
  .artist-gallery-container {
    width: 50%;
    margin-left: auto;
  }
  
  .gallery-item {
    width: 35vw;
  }
}

/* Efectos de entrada */
.animate-in {
  opacity: 1 !important;
  transform: translateY(0) !important;
  transition: opacity 0.8s ease-out, transform 0.8s ease-out;
}
</style>
