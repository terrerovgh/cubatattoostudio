---
---
<header class="main-nav">
  <div class="nav-inner">
    <a href="/" class="logo" aria-label="Cuba Tattoo Studio">
      <img src="/img/logo1.png" alt="logo" />
    </a>
    <nav class="links">
      <a href="#artists">Artists</a>
      <a href="#gallery">Gallery</a>
      <a href="#contact">Contact</a>
    </nav>
    <button class="menu-toggle" aria-label="menu" onclick="document.body.classList.toggle('nav-open')">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<style>
  .main-nav {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 1000;
    background: transparent;
    padding: 0.75rem 1.5rem;
    display: flex;
    justify-content: center;
    pointer-events: none;
  }
  .nav-inner {
    width: 100%;
    max-width: 1200px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    pointer-events: all;
  }
  .logo img {
    height: 36px;
    width: auto;
  }
  .links {
    display: flex;
    gap: 2rem;
  }
  .links a {
    color: #fff;
    text-transform: uppercase;
    font-size: 0.875rem;
    letter-spacing: 0.05em;
    text-decoration: none;
    position: relative;
  }
  .links a::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: -4px;
    width: 0;
    height: 2px;
    background: #fff;
    transition: width 0.3s ease;
  }
  .links a:hover::after {
    width: 100%;
  }
  .menu-toggle {
    display: none;
    flex-direction: column;
    gap: 4px;
    background: transparent;
    border: none;
  }
  .menu-toggle span {
    display: block;
    width: 22px;
    height: 2px;
    background: #fff;
  }
  @media (max-width: 768px) {
    .links {
      display: none;
    }
    body.nav-open .links {
      position: absolute;
      top: 60px;
      left: 0;
      right: 0;
      background: rgba(0, 0, 0, 0.9);
      flex-direction: column;
      align-items: center;
      padding: 1rem 0;
      display: flex;
      gap: 1.5rem;
    }
    .menu-toggle {
      display: flex;
    }
  }
</style>
