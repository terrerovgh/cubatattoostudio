---
import ImageOptimized from '../ImageOptimized.astro';
import Heading from '../Heading.astro';
---
<div class="artist-card opacity-0 transform translate-y-10 border rounded-lg p-4 shadow-lg text-center">
  <ImageOptimized src="https://via.placeholder.com/300x300.png?text=Karli" alt="Artist Karli" width={300} height={300} class="mx-auto rounded-full mb-4" />
  <Heading level={3} text="Karli" class="text-2xl" />
  <p class="text-gray-700 mt-2">Karli is known for intricate geometric and dotwork designs. She creates mesmerizing patterns that flow with the body.</p>
  {/* GSAP animation target class could be added here later */}
</div>
