---
import ImageOptimized from '../ImageOptimized.astro';
import Heading from '../Heading.astro';
---
<div class="artist-card opacity-0 transform translate-y-10 border rounded-lg p-4 shadow-lg text-center">
  <ImageOptimized src="https://via.placeholder.com/300x300.png?text=Nina" alt="Artist Nina" width={300} height={300} class="mx-auto rounded-full mb-4" />
  <Heading level={3} text="Nina" class="text-2xl" />
  <p class="text-gray-700 mt-2">Nina specializes in vibrant watercolor and illustrative tattoos. Her unique style brings any idea to life with color and flair.</p>
  {/* GSAP animation target class could be added here later */}
</div>
