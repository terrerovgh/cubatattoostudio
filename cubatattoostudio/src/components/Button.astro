---
// Button.astro
export interface Props {
  variant?: 'primary' | 'secondary';
  onClick?: () => void;
}
const { variant = 'primary' } = Astro.props;
---
<button class:list={[
  'py-2 px-4 rounded',
  {
    'bg-blue-500 hover:bg-blue-700 text-white': variant === 'primary',
    'bg-gray-500 hover:bg-gray-700 text-white': variant === 'secondary',
  }
]}>
  <slot />
</button>
