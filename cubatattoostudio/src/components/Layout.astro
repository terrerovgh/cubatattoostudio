---
// Layout.astro
import Header from './Header.astro';
import Footer from './Footer.astro';

export interface Props {
  title?: string;
}
const { title = 'Cuba Tattoo Studio' } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" /> {/* Assuming favicon will be in public */}
  <meta name="generator" content={Astro.generator} />
  {/* Any global styles or font links would go here */}
</head>
<body class="flex flex-col min-h-screen">
  <Header slot="header" />
  <main class="flex-grow container mx-auto px-4 py-8">
    <slot /> {/* Default slot for page content */}
  </main>
  <Footer slot="footer" />
</body>
</html>
